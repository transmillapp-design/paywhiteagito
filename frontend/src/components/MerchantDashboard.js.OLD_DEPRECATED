                            const clientName = transaction.description?.replace('Venda para ', '') || 'Cliente';
                            const currentCashbackRate = user?.cashback_rate || 5;
                            
                            // Calcular cashback oferecido
                            const saleAmount = transaction.amount;
                            const fullSaleAmount = saleAmount / (1 - (currentCashbackRate / 100));
                            const cashbackAmount = fullSaleAmount - saleAmount;

                            // Entrada do cashback oferecido (débito)
                            if (cashbackAmount > 0.01) {
                              expandedTransactions.push({
                                ...transaction,
                                id: transaction.id + '_cashback',
                                transaction_type: 'cashback_offered',
                                amount: cashbackAmount,
                                description: `Cashback oferecido - ${clientName}`,
