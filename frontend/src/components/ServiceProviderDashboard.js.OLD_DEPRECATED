                          />
                        </div>
                        <div className="flex items-center space-x-2 pt-6">
                          <input
                            type="checkbox"
                            id="accepts-emergency"
                            checked={profileEditForm.accepts_emergency}
                            onChange={(e) => setProfileEditForm({...profileEditForm, accepts_emergency: e.target.checked})}
                            className="rounded border-gray-300"
                          />
                          <Label htmlFor="accepts-emergency" className="cursor-pointer">Aceito atendimentos de emergência</Label>
                        </div>
                      </div>
                    </div>

                    {/* Configurações de Pagamento */}
                    <div className="border-b pb-6">
                      <h3 className="text-lg font-semibold mb-4">Configurações de Pagamento</h3>
                      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                          <Label>Taxa de Cashback (%)*</Label>
                          <Input
                            type="number"
                            step="0.01"
                            min="0"
                            max="10"
                            value={profileEditForm.cashback_rate}
                            onChange={(e) => setProfileEditForm({...profileEditForm, cashback_rate: e.target.value})}
                            placeholder="5.0"
                            required
                          />
                          <p className="text-xs text-gray-500 mt-1">Valor entre 1% e 10%</p>
                        </div>
                      </div>
                    </div>

                    {/* Endereço */}
                    <div className="border-b pb-6">
                      <h3 className="text-lg font-semibold mb-4">Endereço</h3>
                      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div className="md:col-span-2">
                          <Label>Rua*</Label>
                          <Input
                            value={profileEditForm.address.street}
                            onChange={(e) => setProfileEditForm({
                              ...profileEditForm,
                              address: {...profileEditForm.address, street: e.target.value}
                            })}
                            placeholder="Nome da rua"
                            required
                          />
                        </div>
                        <div>
                          <Label>Número*</Label>
                          <Input
                            value={profileEditForm.address.number}
                            onChange={(e) => setProfileEditForm({
                              ...profileEditForm,
                              address: {...profileEditForm.address, number: e.target.value}
                            })}
                            placeholder="123"
                            required
                          />
                        </div>
                        <div>
                          <Label>Complemento</Label>
                          <Input
                            value={profileEditForm.address.complement}
                            onChange={(e) => setProfileEditForm({
                              ...profileEditForm,
                              address: {...profileEditForm.address, complement: e.target.value}
                            })}
                            placeholder="Apto, Sala, etc"
                          />
                        </div>
                        <div>
                          <Label>Bairro*</Label>
                          <Input
                            value={profileEditForm.address.neighborhood}
                            onChange={(e) => setProfileEditForm({
                              ...profileEditForm,
                              address: {...profileEditForm.address, neighborhood: e.target.value}
                            })}
                            placeholder="Centro"
                            required
                          />
                        </div>
                        <div>
                          <Label>Cidade*</Label>
                          <Input
                            value={profileEditForm.address.city}
                            onChange={(e) => setProfileEditForm({
                              ...profileEditForm,
                              address: {...profileEditForm.address, city: e.target.value}
                            })}
                            placeholder="São Paulo"
                            required
                          />
                        </div>
                        <div>
                          <Label>Estado*</Label>
                          <Input
                            value={profileEditForm.address.state}
                            onChange={(e) => setProfileEditForm({
                              ...profileEditForm,
                              address: {...profileEditForm.address, state: e.target.value}
                            })}
                            placeholder="SP"
                            maxLength="2"
                            required
                          />
                        </div>
                        <div>
                          <Label>CEP*</Label>
                          <Input
                            value={profileEditForm.address.zipcode}
                            onChange={(e) => setProfileEditForm({
                              ...profileEditForm,
                              address: {...profileEditForm.address, zipcode: e.target.value}
                            })}
                            placeholder="01000-000"
                            required
                          />
                        </div>
                      </div>
                    </div>

                    {/* Google Maps */}
                    <div className="pb-4">
                      <h3 className="text-lg font-semibold mb-4">Localização</h3>
                      <div>
                        <Label>URL do Google Maps</Label>
                        <Input
                          value={profileEditForm.google_maps_url}
                          onChange={(e) => setProfileEditForm({...profileEditForm, google_maps_url: e.target.value})}
                          placeholder="https://maps.app.goo.gl/..."
                        />
                        <p className="text-xs text-gray-500 mt-1">
                          Cole o link do Google Maps do seu estabelecimento para facilitar que clientes te encontrem
                        </p>
                      </div>
                    </div>

                    {/* Buttons */}
                    <div className="flex gap-3 pt-4 border-t">
                      <Button type="submit" disabled={loading}>
                        {loading ? (
                          <>
                            <div className="animate-spin rounded-full h-4 w-4 border-2 border-white border-t-transparent mr-2"></div>
                            Salvando...
                          </>
                        ) : (
                          'Salvar Alterações'
                        )}
                      </Button>
                      <Button 
                        type="button" 
                        variant="outline" 
                        onClick={() => {
                          setEditingProfile(false);
                          fetchProfile(); // Recarregar dados originais
                        }}
                      >
                        Cancelar
                      </Button>
                    </div>
                  </form>
                ) : (
                  /* View Mode */
                  <div className="space-y-6">
                    {/* Informações do Negócio */}
                    <div className="border-b pb-6">
                      <h3 className="text-lg font-semibold mb-4">Informações do Negócio</h3>
                      <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                          <Label className="text-gray-600">Nome Fantasia</Label>
                          <p className="font-medium">{profile?.fantasy_name || '-'}</p>
                        </div>
                        <div>
                          <Label className="text-gray-600">Horários</Label>
                          <p className="font-medium">{profile?.working_hours || '-'}</p>
                        </div>
                        <div className="md:col-span-2">
                          <Label className="text-gray-600">Descrição</Label>
                          <p className="font-medium">{profile?.profile_description || '-'}</p>
                        </div>
                        <div>
                          <Label className="text-gray-600">Emergências</Label>
                          <p className="font-medium">{profile?.accepts_emergency ? '✅ Sim' : '❌ Não'}</p>
                        </div>
                      </div>
                    </div>

                    {/* Pagamento */}
                    <div className="border-b pb-6">
                      <h3 className="text-lg font-semibold mb-4">Configurações de Pagamento</h3>
                      <div>
                        <Label className="text-gray-600">Taxa de Cashback</Label>
                        <p className="font-medium text-lg">{((profile?.cashback_rate || 0.05) * 100).toFixed(1)}%</p>
                      </div>
                    </div>

                    {/* Endereço */}
                    <div className="border-b pb-6">
                      <h3 className="text-lg font-semibold mb-4">Endereço</h3>
                      {profile?.address ? (
                        <div className="flex items-start space-x-2">
                          <MapPin size={18} className="text-gray-400 mt-1" />
                          <p className="font-medium">
                            {profile.address.street}, {profile.address.number}
                            {profile.address.complement && ` - ${profile.address.complement}`}
                            <br />
                            {profile.address.neighborhood}, {profile.address.city}/{profile.address.state}
                            <br />
                            CEP: {profile.address.zipcode}
                          </p>
                        </div>
                      ) : (
                        <p className="text-gray-500">Endereço não cadastrado</p>
                      )}
                    </div>

                    {/* Google Maps */}
                    <div>
                      <h3 className="text-lg font-semibold mb-4">Localização</h3>
                      {profile?.google_maps_url ? (
                        <a 
                          href={profile.google_maps_url} 
                          target="_blank" 
                          rel="noopener noreferrer"
                          className="text-blue-600 hover:underline flex items-center space-x-2"
                        >
                          <MapPin size={16} />
                          <span>Ver no Google Maps</span>
                          <ExternalLink size={14} />
                        </a>
                      ) : (
                        <p className="text-gray-500">Link do Google Maps não cadastrado</p>
                      )}
                    </div>
                  </div>
                )}
              </CardContent>
            </Card>
          </TabsContent>
        </Tabs>

        {/* PIX Deposit Modal */}
        {showPixModal && pixDetails && (
          <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
            <Card className="w-full max-w-md m-4">
              <CardHeader>
                <CardTitle className="flex items-center space-x-2">
                  <ArrowDownLeft size={20} />
                  <span>PIX Gerado para Depósito</span>
                </CardTitle>
                <CardDescription>
                  Use o QR Code ou código PIX para realizar o depósito
                </CardDescription>
              </CardHeader>
              <CardContent className="space-y-4">
                <div className="text-center">
                  <div className="bg-white p-4 rounded-lg border">
                    <QRCodeCanvas
                      value={pixDetails.qr_code_pix}
                      size={200}
                      level="M"
                      includeMargin
                    />
                  </div>
                </div>

                <div className="space-y-3">
                  <div className="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                    <span className="font-medium">Valor:</span>
                    <span className="text-lg font-bold text-emerald-600">
                      {formatCurrency(pixDetails.original_amount)}
                    </span>
                  </div>
                  
                  <div className="flex justify-between items-center p-3 bg-gray-50 rounded-lg">
                    <span className="font-medium">Moeda:</span>
                    <span className={`px-2 py-1 rounded text-xs font-medium ${
                      pixDetails.currency === 'USDT' ? 'bg-blue-100 text-blue-800' : 'bg-green-100 text-green-800'
                    }`}>
                      {pixDetails.currency}
                    </span>
                  </div>

                  {pixDetails.currency === 'USDT' && (
                    <div className="flex justify-between items-center p-3 bg-blue-50 rounded-lg">
                      <span className="font-medium">USDT Estimado:</span>
                      <span className="font-bold text-blue-600">
                        {pixDetails.usdt_amount} USDT
                      </span>
                    </div>
                  )}
                </div>

                <div className="space-y-2">
                  <Label className="text-sm font-medium">Código PIX (Copia e Cola):</Label>
                  <div className="flex space-x-2">
                    <Input
                      value={pixDetails.qr_code_pix}
                      readOnly
                      className="text-xs"
                    />
                    <Button
                      variant="outline"
                      size="sm"
                      onClick={() => {
                        navigator.clipboard?.writeText(pixDetails.qr_code_pix);
                        alert('Código PIX copiado!');
                      }}
                    >
                      <Copy size={16} />
                    </Button>
                  </div>
                </div>

                <div className="p-3 bg-yellow-50 border border-yellow-200 rounded-lg">
                  <p className="text-sm text-yellow-800">
                    <strong>⏰ Importante:</strong> O PIX expira em 30 minutos. 
                    O saldo será creditado automaticamente após o pagamento.
                  </p>
                </div>

                <Button
                  onClick={() => {
                    setShowPixModal(false);
                    setPixDetails(null);
                  }}
                  className="w-full"
                >
                  Fechar
                </Button>
              </CardContent>
            </Card>
          </div>
        )}

        {/* QR Code Modal */}
        {qrCodeData && (
          <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
            <Card className="w-full max-w-md m-4">
              <CardHeader>
                <CardTitle>Pagamento Gerado com Sucesso! 🎉</CardTitle>
                <CardDescription>Mostre este QR Code para o cliente pagar</CardDescription>
              </CardHeader>
              <CardContent className="space-y-4">
                <div className="bg-white p-4 rounded-lg border-2 border-gray-200">
                  <div className="text-center">
                    <QrCode className="mx-auto mb-2" size={100} />
                    <p className="text-sm text-gray-600">QR Code para pagamento</p>
                  </div>
                </div>
                <div>
                  <Label>Código Digital</Label>
                  <div className="flex gap-2">
                    <Input value={qrCodeData.digital_code} readOnly />
                    <Button onClick={() => navigator.clipboard.writeText(qrCodeData.digital_code)}>
                      Copiar
                    </Button>
                  </div>
                </div>
                <div className="bg-blue-50 p-3 rounded">
                  <p className="text-sm"><strong>Valor:</strong> R$ {qrCodeData.amount?.toFixed(2)}</p>
                  <p className="text-sm"><strong>Serviço:</strong> {qrCodeData.service_name}</p>
                  <p className="text-sm"><strong>Cashback:</strong> {(qrCodeData.cashback_rate * 100).toFixed(0)}%</p>
                </div>
                <Button className="w-full" onClick={() => setQrCodeData(null)}>Fechar</Button>
              </CardContent>
            </Card>
          </div>
        )}

        {/* Modal de Perfil Completo */}
        <ServiceProviderProfileModal
          isOpen={showProfileModal}
          onClose={() => setShowProfileModal(false)}
          user={user}
          profile={profile}
        />
      </div>
    </div>
  );
};

export default ServiceProviderDashboard;
