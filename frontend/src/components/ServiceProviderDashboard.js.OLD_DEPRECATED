import React, { useState, useEffect } from 'react';
import { useAuth } from '../App';
import { useSearchParams } from 'react-router-dom';
import { 
  Briefcase, 
  Calendar, 
  DollarSign, 
  Clock,
  Plus,
  Edit2,
  Trash2,
  Check,
  X,
  Eye,
  QrCode,
  User,
  Phone,
  MapPin,
  Star,
  TrendingUp,
  Settings,
  LogOut,
  ExternalLink,
  History,
  Users,
  Copy,
  Share2,
  ArrowUpRight,
  ArrowDownLeft,
  FileImage,
  Coins
} from 'lucide-react';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from './ui/card';
import { Button } from './ui/button';
import { Input } from './ui/input';
import { Label } from './ui/label';
import { Tabs, TabsContent, TabsList, TabsTrigger } from './ui/tabs';
import { Select, SelectContent, SelectItem, SelectTrigger, SelectValue } from './ui/select';
import { QRCodeCanvas } from 'qrcode.react';
import ReferralSystem from './ReferralSystem';
import CompleteUserProfile from './CompleteUserProfile';
import USDTCalculator from './USDTCalculator';
import USDTTransfer from './USDTTransfer';
import SubUsersManager from './SubUsersManager';
import { Dialog, DialogContent, DialogHeader, DialogTitle, DialogTrigger } from './ui/dialog';
import { Avatar, AvatarFallback, AvatarImage } from './ui/avatar';
import ServiceProviderProfileModal from './ServiceProviderProfileModal';

const ServiceProviderDashboard = ({ user, onLogout }) => {
  const [searchParams] = useSearchParams();
  const [activeTab, setActiveTab] = useState('services');
  const [services, setServices] = useState([]);
  const [appointments, setAppointments] = useState([]);
  const [profile, setProfile] = useState(null);
  const [loading, setLoading] = useState(false);
  const [showServiceForm, setShowServiceForm] = useState(false);
  const [editingService, setEditingService] = useState(null);
  const [qrCodeData, setQrCodeData] = useState(null);
  const [editingProfile, setEditingProfile] = useState(false);
  const [showProfileModal, setShowProfileModal] = useState(false);
  
  // POS states
  const [posAmount, setPosAmount] = useState('');
  const [posDescription, setPosDescription] = useState('');
  const [generatedQRCode, setGeneratedQRCode] = useState(null);
  const [digitalCodeGenerated, setDigitalCodeGenerated] = useState('');
  
  // Transactions states
  const [transactions, setTransactions] = useState([]);
  const [transactionsLoading, setTransactionsLoading] = useState(false);
  
  // Deposit states
  const [depositData, setDepositData] = useState({ 
    amount: '', 
    method: 'pix', 
    currency: 'BRL' 
  });
  const [depositLoading, setDepositLoading] = useState(false);
  const [pixDetails, setPixDetails] = useState(null);
  const [showPixModal, setShowPixModal] = useState(false);
  const [exchangeRate, setExchangeRate] = useState(null);
  
  const [serviceForm, setServiceForm] = useState({
    name: '',
    description: '',
    price: '',
    estimated_duration: '60',
    category: 'geral'
  });

  const [profileEditForm, setProfileEditForm] = useState({
    fantasy_name: '',
    profile_description: '',
    working_hours: '',
    accepts_emergency: false,
    cashback_rate: '0.05',
    google_maps_url: '',
    address: {
      street: '',
      number: '',
      complement: '',
      neighborhood: '',
      city: '',
      state: '',
      zipcode: ''
    }
  });

  // Buscar perfil do prestador
  useEffect(() => {
    fetchProfile();
    fetchServices();
    fetchAppointments();
    fetchExchangeRate(); // Load exchange rate
  }, []);

  // Ler parâmetro tab da URL
  useEffect(() => {
    const tabParam = searchParams.get('tab');
    if (tabParam) {
      console.log('Setting service provider tab from URL:', tabParam);
      setActiveTab(tabParam);
    }
  }, [searchParams]);

  const fetchProfile = async () => {
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/prestador/profile`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      if (data.success) {
        setProfile(data.data);
        // Preencher formulário de edição
        setProfileEditForm({
          fantasy_name: data.data.fantasy_name || '',
          profile_description: data.data.profile_description || '',
          working_hours: data.data.working_hours || '',
          accepts_emergency: data.data.accepts_emergency || false,
          cashback_rate: data.data.cashback_rate?.toString() || '0.05',
          google_maps_url: data.data.google_maps_url || '',
          address: data.data.address || {
            street: '',
            number: '',
            complement: '',
            neighborhood: '',
            city: '',
            state: '',
            zipcode: ''
          }
        });
      }
    } catch (error) {
      console.error('Erro ao buscar perfil:', error);
    }
  };

  const fetchServices = async () => {
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/prestador/servicos`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      if (data.success) {
        setServices(data.data);
      }
    } catch (error) {
      console.error('Erro ao buscar serviços:', error);
    }
  };

  const fetchAppointments = async () => {
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/prestador/agendamentos`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      if (data.success) {
        setAppointments(data.data);
      }
    } catch (error) {
      console.error('Erro ao buscar agendamentos:', error);
    }
  };

  const handleCreateService = async (e) => {
    e.preventDefault();
    setLoading(true);
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/prestador/servicos`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(serviceForm)
      });
      const data = await response.json();
      if (data.success) {
        alert('Serviço criado com sucesso!');
        fetchServices();
        setShowServiceForm(false);
        setServiceForm({ name: '', description: '', price: '', estimated_duration: '60', category: 'geral' });
      } else {
        alert(data.message || 'Erro ao criar serviço');
      }
    } catch (error) {
      alert('Erro ao criar serviço');
    } finally {
      setLoading(false);
    }
  };

  const handleUpdateService = async (e) => {
    e.preventDefault();
    setLoading(true);
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/prestador/servicos/${editingService.id}`, {
        method: 'PUT',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(serviceForm)
      });
      const data = await response.json();
      if (data.success) {
        alert('Serviço atualizado com sucesso!');
        fetchServices();
        setEditingService(null);
        setServiceForm({ name: '', description: '', price: '', estimated_duration: '60', category: 'geral' });
      } else {
        alert(data.message || 'Erro ao atualizar serviço');
      }
    } catch (error) {
      alert('Erro ao atualizar serviço');
    } finally {
      setLoading(false);
    }
  };

  const handleDeleteService = async (serviceId) => {
    if (!window.confirm('Deseja realmente desativar este serviço?')) return;
    
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/prestador/servicos/${serviceId}`, {
        method: 'DELETE',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      if (data.success) {
        alert('Serviço desativado com sucesso!');
        fetchServices();
      }
    } catch (error) {
      alert('Erro ao desativar serviço');
    }
  };

  const handleUpdateAppointmentStatus = async (appointmentId, status) => {
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/prestador/agendamentos/${appointmentId}/status`, {
        method: 'PUT',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ status })
      });
      const data = await response.json();
      if (data.success) {
        alert(`Status atualizado: ${status}`);
        fetchAppointments();
      }
    } catch (error) {
      alert('Erro ao atualizar status');
    }
  };

  const handleCompleteAppointment = async (appointmentId) => {
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/prestador/agendamentos/${appointmentId}/concluir`, {
        method: 'POST',
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      if (data.success) {
        setQrCodeData(data.data);
        fetchAppointments();
      }
    } catch (error) {
      alert('Erro ao concluir agendamento');
    }
  };

  const editService = (service) => {
    setEditingService(service);
    setServiceForm({
      name: service.name,
      description: service.description,
      price: service.price,
      estimated_duration: service.estimated_duration,
      category: service.category
    });
  };

  const cancelEdit = () => {
    setEditingService(null);
    setServiceForm({ name: '', description: '', price: '', estimated_duration: '60', category: 'geral' });
  };

  const handleUpdateProfile = async (e) => {
    e.preventDefault();
    setLoading(true);
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/prestador/profile`, {
        method: 'PUT',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify(profileEditForm)
      });
      const data = await response.json();
      if (data.success) {
        alert('Perfil atualizado com sucesso!');
        fetchProfile();
        setEditingProfile(false);
      } else {
        alert(data.message || 'Erro ao atualizar perfil');
      }
    } catch (error) {
      alert('Erro ao atualizar perfil');
    } finally {
      setLoading(false);
    }
  };

  // POS Functions
  const generatePOSQRCode = async () => {
    if (!posAmount || parseFloat(posAmount) <= 0) {
      alert('Por favor, insira um valor válido');
      return;
    }

    try {
      setLoading(true);
      const token = localStorage.getItem('token');
      
      // Gerar QR Code via backend
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/prestador/pos/generate`, {
        method: 'POST',
        headers: {
          'Authorization': `Bearer ${token}`,
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({
          amount: parseFloat(posAmount),
          description: posDescription || 'Pagamento de serviço'
        })
      });

      const data = await response.json();
      
      if (data.success) {
        setGeneratedQRCode(data.data.qr_code);
        setDigitalCodeGenerated(data.data.digital_code);
        alert('QR Code gerado com sucesso!');
      } else {
        alert(data.message || 'Erro ao gerar QR Code');
      }
    } catch (error) {
      alert('Erro ao gerar QR Code');
    } finally {
      setLoading(false);
    }
  };

  const clearPOSForm = () => {
    setPosAmount('');
    setPosDescription('');
    setGeneratedQRCode(null);
    setDigitalCodeGenerated('');
  };

  const copyDigitalCode = () => {
    if (digitalCodeGenerated) {
      navigator.clipboard.writeText(digitalCodeGenerated);
      alert('Código copiado!');
    }
  };

  // Transactions Functions
  const fetchTransactions = async () => {
    try {
      setTransactionsLoading(true);
      const token = localStorage.getItem('token');
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/user/transactions`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      if (data.transactions) {
        setTransactions(data.transactions);
      }
    } catch (error) {
      console.error('Erro ao buscar transações:', error);
    } finally {
      setTransactionsLoading(false);
    }
  };

  const formatDateTime = (dateString) => {
    return new Date(dateString).toLocaleString('pt-BR');
  };

  const getStatusBadge = (status) => {
    const badges = {
      pending: { color: 'bg-yellow-100 text-yellow-800', text: 'Pendente' },
      confirmed: { color: 'bg-blue-100 text-blue-800', text: 'Confirmado' },
      in_progress: { color: 'bg-purple-100 text-purple-800', text: 'Em Andamento' },
      completed: { color: 'bg-green-100 text-green-800', text: 'Concluído' },
      cancelled: { color: 'bg-red-100 text-red-800', text: 'Cancelado' }
    };
    const badge = badges[status] || badges.pending;
    return <span className={`px-2 py-1 rounded-full text-xs font-medium ${badge.color}`}>{badge.text}</span>;
  };

  // Deposit Functions
  const handleDeposit = async (e) => {
    e.preventDefault();
    setDepositLoading(true);

    try {
      let response;
      const amount = parseFloat(depositData.amount);
      const token = localStorage.getItem('token');
      
      if (depositData.method === 'pix') {
        // Depósito direto em BRL via XGate PIX
        response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/xgate/pix-deposit`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ 
            amount: amount,
            description: `Depósito Prestador AgitoCoin via PIX - R$ ${amount.toFixed(2)}`
          })
        });
      } else if (depositData.method === 'pix-usdt') {
        // Depósito convertido para USDT via XGate
        response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/xgate/convert-brl-usdt`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Authorization': `Bearer ${token}`
          },
          body: JSON.stringify({ 
            brl_amount: amount
          })
        });
      }
      
      const data = await response.json();
      
      if (data.success) {
        const pixData = data.data;
        
        // Store PIX details and show modal
        setPixDetails({
          ...pixData,
          currency: depositData.method === 'pix-usdt' ? 'USDT' : 'BRL',
          original_amount: amount
        });
        setShowPixModal(true);
        
        const currency = depositData.method === 'pix-usdt' ? 'USDT' : 'BRL';
        // Toast seria ideal, mas vamos usar alert simples por agora
        alert(`PIX gerado com sucesso para depósito em ${currency}! Use o QR Code para pagar.`);
      } else {
        throw new Error(data.error || 'Erro ao gerar PIX');
      }
      
      setDepositData({ amount: '', method: 'pix', currency: 'BRL' });
      fetchProfile(); // Refresh data
    } catch (error) {
      console.error('Deposit error:', error);
      alert(`Erro ao realizar depósito: ${error.message}`);
    } finally {
      setDepositLoading(false);
    }
  };

  // Função para buscar taxa de câmbio
  const fetchExchangeRate = async () => {
    try {
      const token = localStorage.getItem('token');
      const response = await fetch(`${process.env.REACT_APP_BACKEND_URL}/xgate/exchange-rate`, {
        headers: { 'Authorization': `Bearer ${token}` }
      });
      const data = await response.json();
      if (data.success) {
        setExchangeRate(data.data.rate);
      }
    } catch (error) {
      console.error('Error fetching exchange rate:', error);
    }
  };

  const formatCurrency = (value) => {
    return new Intl.NumberFormat('pt-BR', {
      style: 'currency',
      currency: 'BRL'
    }).format(value);
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-blue-50 to-indigo-50 p-4">
      <div className="max-w-7xl mx-auto">
        {/* Header */}
        <div className="bg-white rounded-xl shadow-sm p-6 mb-6">
          <div className="flex justify-between items-center">
            <div className="flex items-center space-x-4">
              <div className="w-16 h-16 bg-gradient-to-br from-blue-500 to-indigo-600 rounded-full flex items-center justify-center text-white text-2xl font-bold">
                {user?.full_name?.charAt(0) || 'P'}
              </div>
              <div>
                <h1 className="text-2xl font-bold text-gray-800">Olá, {user?.full_name || 'Prestador'}! 👋</h1>
                <p className="text-gray-600">{profile?.fantasy_name || 'Seu Negócio'}</p>
                <div className="flex items-center space-x-2 mt-1">
                  <Star className="text-yellow-400" size={16} />
                  <span className="text-sm font-semibold">{profile?.rating_average?.toFixed(1) || '0.0'}</span>
                  <span className="text-gray-500 text-sm">({profile?.rating_count || 0} avaliações)</span>
                </div>
              </div>
            </div>
            <div className="flex gap-2">
              <Button variant="outline" onClick={() => setShowProfileModal(true)}>
                <User size={16} className="mr-2" />
                Meu Perfil
              </Button>
              <Button variant="outline" onClick={onLogout}>
                <LogOut size={16} className="mr-2" />
                Sair
              </Button>
            </div>
          </div>
        </div>

        {/* Stats Cards */}
        <div className="grid grid-cols-1 md:grid-cols-4 gap-4 mb-6">
          <Card>
            <CardContent className="p-6">
              <div className="flex items-center justify-between">
                <div>
                  <p className="text-sm text-gray-600">Saldo</p>
                  <p className="text-2xl font-bold text-green-600">R$ {user?.balance?.toFixed(2) || '0,00'}</p>
                </div>
                <DollarSign className="text-green-500" size={32} />
              </div>
            </CardContent>
          </Card>
          
          <Card>
            <CardContent className="p-6">
              <div className="flex items-center justify-between">
                <div>
                  <p className="text-sm text-gray-600">Serviços</p>
                  <p className="text-2xl font-bold text-blue-600">{services.length}</p>
                </div>
                <Briefcase className="text-blue-500" size={32} />
              </div>
            </CardContent>
          </Card>
          
          <Card>
            <CardContent className="p-6">
              <div className="flex items-center justify-between">
                <div>
                  <p className="text-sm text-gray-600">Agendamentos</p>
                  <p className="text-2xl font-bold text-purple-600">{appointments.length}</p>
                </div>
                <Calendar className="text-purple-500" size={32} />
              </div>
            </CardContent>
          </Card>
          
          <Card>
            <CardContent className="p-6">
              <div className="flex items-center justify-between">
                <div>
                  <p className="text-sm text-gray-600">Avaliação</p>
                  <p className="text-2xl font-bold text-yellow-600">{profile?.rating_average?.toFixed(1) || '0.0'} ⭐</p>
                </div>
                <TrendingUp className="text-yellow-500" size={32} />
              </div>
            </CardContent>
          </Card>
        </div>

        {/* Main Content */}
        <Tabs value={activeTab} onValueChange={setActiveTab} className="space-y-4">
          <TabsList className="grid w-full grid-cols-10 bg-white text-xs sm:text-sm">
            <TabsTrigger value="services" className="px-2">
              <Briefcase className="mr-1 sm:mr-2" size={14} />
              <span className="hidden sm:inline">Serviços</span>
              <span className="sm:hidden">Serv</span>
            </TabsTrigger>
            <TabsTrigger value="appointments" className="px-2">
              <Calendar className="mr-1 sm:mr-2" size={14} />
              <span className="hidden sm:inline">Agendamentos</span>
              <span className="sm:hidden">Agenda</span>
            </TabsTrigger>
            <TabsTrigger value="pos" className="px-2">
              <QrCode className="mr-1 sm:mr-2" size={14} />
              <span>POS</span>
            </TabsTrigger>
            <TabsTrigger value="transactions" className="px-2">
              <History className="mr-1 sm:mr-2" size={14} />
              <span className="hidden sm:inline">Extrato</span>
              <span className="sm:hidden">Ext</span>
            </TabsTrigger>
            <TabsTrigger value="deposit" className="px-2">
              <ArrowDownLeft className="mr-1 sm:mr-2" size={14} />
              <span className="hidden sm:inline">Depósito</span>
              <span className="sm:hidden">Dep</span>
            </TabsTrigger>
            <TabsTrigger value="referral" className="px-2">
              <Users className="mr-1 sm:mr-2" size={14} />
              <span className="hidden sm:inline">Indicar</span>
              <span className="sm:hidden">Ind</span>
            </TabsTrigger>
            <TabsTrigger value="documents" className="px-2">
              <FileImage className="mr-1 sm:mr-2" size={14} />
              <span className="hidden sm:inline">Docs</span>
              <span className="sm:hidden">Doc</span>
            </TabsTrigger>
            <TabsTrigger value="profile" className="px-2">
              <User className="mr-1 sm:mr-2" size={14} />
              <span className="hidden sm:inline">Perfil</span>
              <span className="sm:hidden">Perf</span>
            </TabsTrigger>
            <TabsTrigger value="usdt" className="px-2">
              <Coins className="mr-1 sm:mr-2" size={14} />
              <span>USDT</span>
            </TabsTrigger>
            <TabsTrigger value="settings" className="px-2">
              <Settings className="mr-1 sm:mr-2" size={14} />
              <span className="hidden sm:inline">Config</span>
              <span className="sm:hidden">Cfg</span>
            </TabsTrigger>
          </TabsList>

          {/* Services Tab */}
          <TabsContent value="services">
            <Card>
              <CardHeader>
                <div className="flex justify-between items-center">
                  <div>
                    <CardTitle>Gerenciar Serviços</CardTitle>
                    <CardDescription>Cadastre e gerencie os serviços que você oferece</CardDescription>
                  </div>
                  <Button onClick={() => setShowServiceForm(!showServiceForm)}>
                    <Plus size={16} className="mr-2" />
                    Novo Serviço
                  </Button>
                </div>
              </CardHeader>
              <CardContent>
                {(showServiceForm || editingService) && (
                  <form onSubmit={editingService ? handleUpdateService : handleCreateService} className="mb-6 p-4 bg-gray-50 rounded-lg">
                    <h4 className="font-semibold mb-4">{editingService ? 'Editar Serviço' : 'Novo Serviço'}</h4>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                      <div className="md:col-span-2">
                        <Label>Nome do Serviço*</Label>
                        <Input
                          value={serviceForm.name}
                          onChange={(e) => setServiceForm({...serviceForm, name: e.target.value})}
                          placeholder="Ex: Instalação Elétrica"
                          required
                        />
                      </div>
                      <div className="md:col-span-2">
                        <Label>Descrição</Label>
                        <textarea
                          value={serviceForm.description}
                          onChange={(e) => setServiceForm({...serviceForm, description: e.target.value})}
                          placeholder="Descreva o serviço oferecido..."
                          className="w-full px-3 py-2 border border-gray-300 rounded-md"
                          rows="3"
                        />
                      </div>
                      <div>
                        <Label>Preço (R$)*</Label>
                        <Input
                          type="number"
                          step="0.01"
                          value={serviceForm.price}
                          onChange={(e) => setServiceForm({...serviceForm, price: e.target.value})}
                          placeholder="150.00"
                          required
                        />
                      </div>
                      <div>
                        <Label>Duração (minutos)*</Label>
                        <Input
                          type="number"
                          value={serviceForm.estimated_duration}
                          onChange={(e) => setServiceForm({...serviceForm, estimated_duration: e.target.value})}
                          placeholder="60"
                          required
                        />
                      </div>
                      <div className="md:col-span-2">
