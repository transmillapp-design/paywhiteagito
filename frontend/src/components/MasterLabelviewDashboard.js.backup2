                        <th className="px-4 py-2 text-left text-xs font-medium text-gray-500">CPF</th>
                        <th className="px-4 py-2 text-left text-xs font-medium text-gray-500">Cargo</th>
                        <th className="px-4 py-2 text-left text-xs font-medium text-gray-500">Regional</th>
