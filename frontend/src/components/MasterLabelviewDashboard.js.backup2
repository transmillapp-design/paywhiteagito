                      onClick={() => {
                        setActiveTab('planos');
                        fetchPlanos();
                        setShowPlanosListModal(true);
                      }}
                      className="w-full flex items-center gap-2 px-4 py-2 rounded-lg text-sm text-gray-600 hover:bg-gray-100"
                    >
                      <FileText size={18} />
                      <span>Listar Planos</span>
                    </button>
                  </div>
                )}
