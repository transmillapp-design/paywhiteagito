                        <th className="px-4 py-2 text-left text-xs font-medium text-gray-500">Email</th>
                        <th className="px-4 py-2 text-left text-xs font-medium text-gray-500">Regional</th>
                        <th className="px-4 py-2 text-left text-xs font-medium text-gray-500">Vendas</th>
                        <th className="px-4 py-2 text-left text-xs font-medium text-gray-500">Comissão</th>
