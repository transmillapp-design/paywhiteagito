@labelview_router.get("/clients/{client_id}")
async def get_client_details(
    client_id: str,
    current_user = Depends(get_current_user_dependency)
):
    """Detalhes completos do cliente"""
    from server import db as db_instance
    await verify_labelview_master(current_user["id"])
    
    try:
        client = await db_instance.labelview_clients.find_one({'id': client_id})
        
        if not client:
            raise HTTPException(status_code=404, detail="Cliente não encontrado")
        
        # Buscar pagamentos do cliente
        payments = await db_instance.labelview_payments.find({'client_id': client_id}).to_list(length=1000)
        
        # Buscar solicitações de serviço
        service_requests = await db_instance.labelview_service_requests.find({'client_id': client_id}).to_list(length=1000)
        
        return {
            'success': True,
            'client': client,
            'payments': payments,
            'service_requests': service_requests
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error fetching client details: {e}")
        raise HTTPException(status_code=500, detail=str(e))

# ============================================
# SOLICITAÇÕES DE SERVIÇO
# ============================================

@labelview_router.get("/service-requests")
@labelview_router.get("/solicitacoes")  # 🔧 ALIAS: Endpoint em português
async def get_service_requests(
    status: Optional[str] = None,
    type: Optional[str] = None,
    current_user = Depends(get_current_user_dependency)
):
    """Listar solicitações de serviço"""
    from server import db as db_instance
    
    # 🔧 CORREÇÃO: Permitir todos os tipos de usuário Labelview ver solicitações
    user_type = current_user.get('user_type')
    user_id = current_user.get('id')
    
    try:
        query = {}
        
        # Filtros opcionais
        if status:
            query['status'] = status
        if type:
            query['type'] = type
        
        # 🔧 Aplicar filtro hierárquico
        if user_type == 'labelview_master':
            # Master vê todas
            pass
        elif user_type == 'labelview_unidade':
            # Unidade vê solicitações de sua rede
            query['unidade_id'] = user_id
        elif user_type == 'labelview_regional':
            # Regional vê solicitações de seus consultores
            query['regional_id'] = user_id
        elif user_type == 'labelview_consultor':
            # Consultor vê apenas suas solicitações
            query['consultor_id'] = user_id
        elif user_type == 'labelview_fornecedor':
            # Fornecedor vê solicitações atribuídas a ele
            query['assigned_to'] = user_id
        
        logger.info(f"📋 Buscando solicitações - User: {user_type}, Query: {query}")
        
        requests = await db_instance.labelview_service_requests.find(query).sort('requested_at', -1).to_list(length=1000)
        
        logger.info(f"✅ Encontradas {len(requests)} solicitações")
        
        return {
            'success': True,
            'requests': requests,
            'total': len(requests)
        }
    except Exception as e:
        logger.error(f"❌ Error fetching service requests: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@labelview_router.post("/service-requests")
async def create_service_request(
    request_data: dict,
    current_user = Depends(get_current_user_dependency)
):
    """Criar solicitação de serviço"""
    from server import db as db_instance
    await verify_labelview_master(current_user["id"])
    
    try:
        service_request = {
            'id': str(uuid4()),
            'client_id': request_data['client_id'],
            'type': request_data['type'],
            'status': 'pending',
            'description': request_data['description'],
            'location': request_data.get('location'),
            'priority': request_data.get('priority', 'normal'),
            'assigned_to': request_data.get('assigned_to'),
            'provider_id': request_data.get('provider_id'),
            'requested_at': datetime.utcnow(),
            'estimated_cost': request_data.get('estimated_cost', 0.0),
            'photos': request_data.get('photos', []),
            'documents': request_data.get('documents', []),
            'notes': request_data.get('notes')
        }
        
        await db_instance.labelview_service_requests.insert_one(service_request)
        
        return {
            'success': True,
            'message': 'Solicitação criada com sucesso',
            'request': service_request
        }
    except Exception as e:
        logger.error(f"Error creating service request: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@labelview_router.patch("/service-requests/{request_id}")
async def update_service_request(
    request_id: str,
    update_data: dict,
    current_user = Depends(get_current_user_dependency)
):
    """Atualizar solicitação de serviço"""
    from server import db as db_instance
    await verify_labelview_master(current_user["id"])
    
    try:
        # Se mudou para in_progress, registrar data
        if update_data.get('status') == 'in_progress' and 'started_at' not in update_data:
            update_data['started_at'] = datetime.utcnow()
        
        # Se completou, registrar data
        if update_data.get('status') == 'completed' and 'completed_at' not in update_data:
            update_data['completed_at'] = datetime.utcnow()
        
        result = await db_instance.labelview_service_requests.update_one(
            {'id': request_id},
            {'$set': update_data}
        )
        
        if result.modified_count == 0:
            raise HTTPException(status_code=404, detail="Solicitação não encontrada")
        
        return {
            'success': True,
            'message': 'Solicitação atualizada com sucesso'
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error updating service request: {e}")
        raise HTTPException(status_code=500, detail=str(e))

