# Cache para db (inicializado na primeira chamada)
_db_cache = None

def get_db():
    """Obter db com cache"""
    global _db_cache
    if _db_cache is None:
        from server import db
        _db_cache = db
    return _db_cache

# Usar import lazy de db para evitar circular import
# db será acessado via função auxiliar
def get_db_lazy():
    """Lazy load do db"""
    import server
    return server.db

# Criar wrapper que funciona como db mas faz import lazy
class LazyDbProxy:
    def __getattribute__(self, name):
        if name == '__class__':
            return object.__getattribute__(self, name)
        db_instance = get_db_lazy()
        return getattr(db_instance, name)

db = LazyDbProxy()

# Função wrapper para evitar circular import
async def get_current_user_dependency(request: Request):
    """Wrapper para get_current_user que resolve em runtime"""
    from server import db as db_instance
    import jwt
    import os
    
    # Extrai o token do header
    auth_header = request.headers.get("Authorization")
    if not auth_header:
        raise HTTPException(status_code=401, detail="Token não fornecido")
    
    try:
        token = auth_header.replace("Bearer ", "")
        SECRET_KEY = os.environ.get('JWT_SECRET', 'agitocoin_secret_key_2024')
        payload = jwt.decode(token, SECRET_KEY, algorithms=["HS256"])
        user_id = payload.get("sub")
        
        if not user_id:
            raise HTTPException(status_code=401, detail="Token inválido")
        
        user_data = await db_instance.users.find_one({"id": user_id})
        if not user_data:
            raise HTTPException(status_code=401, detail="Usuário não encontrado")
        
        # Retornar dict ao invés de User object
        user_data.pop('_id', None)
        return user_data
    except jwt.ExpiredSignatureError:
        raise HTTPException(status_code=401, detail="Token expirado")
    except jwt.InvalidTokenError:
        raise HTTPException(status_code=401, detail="Token inválido")
    except Exception as e:
        logger.error(f"Error in authentication: {e}")
        raise HTTPException(status_code=401, detail="Erro na autenticação")

# ============================================
# HELPERS
# ============================================

async def verify_labelview_master(user_id: str):
    """Verifica se o usuário é master da Labelview"""
    
    from server import db as db_instance
    user = await db_instance.users.find_one({'id': user_id})
    if not user or not user.get('is_labelview_master'):
        raise HTTPException(status_code=403, detail="Acesso negado. Apenas Master Labelview.")
    return user

# ============================================
# LINK DE INDICAÇÃO / REFERRAL
# ============================================

@labelview_router.get("/verificar-link/{user_id}")
async def verificar_link_indicacao(user_id: str):
    """
    Verifica se o link de indicação é válido
    Retorna informações do vendedor (Unidade, Regional ou Consultor)
    """
    from server import db as db_instance
    
    try:
        # Buscar usuário pelo ID
        user = await db_instance.users.find_one({'id': user_id})
        
        if not user:
            raise HTTPException(status_code=404, detail="Link inválido ou expirado")
        
        # Verificar se o usuário pode ter link de indicação (apenas Unidade, Regional, Consultor)
        valid_types = ['labelview_unidade', 'labelview_regional', 'labelview_consultor']
        
        if user.get('user_type') not in valid_types:
            raise HTTPException(status_code=403, detail="Este usuário não pode enviar indicações")
        
        # Retornar informações do vendedor com campos corretos baseados no tipo
        vendedor_data = {
            'id': user.get('id'),
            'nome': user.get('nome_fantasia') or user.get('full_name'),
            'tipo': user.get('user_type'),
            'logo_url': user.get('logo_url'),
            'cor_primaria': user.get('cor_primaria'),
            'cor_secundaria': user.get('cor_secundaria')
        }
        
        # Adicionar campos específicos por tipo para o frontend
        if user.get('user_type') == 'labelview_unidade':
            vendedor_data['nome_fantasia'] = user.get('nome_fantasia')
            vendedor_data['full_name'] = user.get('nome_fantasia')  # Unidade usa nome_fantasia
        elif user.get('user_type') == 'labelview_regional':
            vendedor_data['nome_fantasia'] = user.get('nome_fantasia')
            vendedor_data['full_name'] = user.get('nome_fantasia')  # Regional usa nome_fantasia
        else:  # labelview_consultor
            # Consultor pode ser CPF (full_name) ou CNPJ (nome_fantasia)
            vendedor_data['full_name'] = user.get('full_name') or user.get('nome_fantasia')
            if user.get('nome_fantasia'):
                vendedor_data['nome_fantasia'] = user.get('nome_fantasia')
        
        # Retornar informações do vendedor
        return {
            'success': True,
            'vendedor': vendedor_data
        }
    
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Erro ao verificar link: {str(e)}")
        raise HTTPException(status_code=500, detail="Erro ao verificar link")

