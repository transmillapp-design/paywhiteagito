@labelview_router.get("/crm/leads")
async def get_crm_leads(
    current_user = Depends(get_current_user_dependency)
):
    """Listar leads do CRM"""
    from server import db as db_instance
    await verify_labelview_master(current_user["id"])
    
    try:
        leads = await db_instance.labelview_crm_leads.find({}).to_list(length=1000)
        
        # Remover _id do MongoDB
        for lead in leads:
            lead.pop('_id', None)
        
        return {
            'success': True,
            'leads': leads,
            'total': len(leads)
        }
    except Exception as e:
        logger.error(f"Error fetching CRM leads: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.get("/crm/protecoes")
async def get_crm_protecoes(
    current_user = Depends(get_current_user_dependency)
):
    """Listar proteções por status (funil de vendas) - Respeitando hierarquia"""
    from server import db as db_instance
    
    try:
        # 🔧 Filtrar por hierarquia
        filtro = {}
        user_type = current_user.get('user_type')
        
        if user_type == 'labelview_consultor':
            # Consultor vê apenas suas próprias proteções
            filtro['consultor_id'] = current_user['id']
        elif user_type == 'labelview_regional':
            # Regional vê suas próprias + dos consultores da regional
            filtro['$or'] = [
                {'regional_id': current_user['id']},
                {'consultor_id': {'$in': await get_consultores_ids_da_regional(current_user['id'], db_instance)}}
            ]
        elif user_type == 'labelview_unidade':
            # Unidade vê tudo da unidade (regionais + consultores)
            filtro['unidade_id'] = current_user['id']
        elif current_user.get('is_labelview_master'):
            # Master vê tudo
            pass
        else:
            # Outros tipos não têm acesso
            raise HTTPException(status_code=403, detail="Sem permissão para acessar CRM")
        
        # Buscar proteções com filtro
        all_protecoes = await db_instance.labelview_crm_protecoes.find(filtro).to_list(length=1000)
        
        # Organizar por status
        interesse = []
        negociacao = []
        aguardando_aprovacao = []
        
        for protecao in all_protecoes:
            protecao.pop('_id', None)
            
            status = protecao.get('status', 'interesse')
            if status == 'interesse':
                interesse.append(protecao)
            elif status == 'negociacao':
                negociacao.append(protecao)
            elif status == 'aguardando_aprovacao':
                aguardando_aprovacao.append(protecao)
        
        return {
            'success': True,
            'interesse': interesse,
            'negociacao': negociacao,
            'aguardando_aprovacao': aguardando_aprovacao,
            'total': len(all_protecoes)
        }
    except Exception as e:
        logger.error(f"Error fetching CRM protecoes: {e}")
        raise HTTPException(status_code=500, detail=str(e))


async def get_consultores_ids_da_regional(regional_id: str, db_instance):
    """Helper para buscar IDs dos consultores de uma regional"""
    consultores = await db_instance.users.find({'regional_id': regional_id, 'user_type': 'labelview_consultor'}).to_list(length=1000)
    return [c['id'] for c in consultores]


