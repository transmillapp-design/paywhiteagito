        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.post("/planos/criar-automatico")
async def criar_planos_automaticos(
    request: Request,
    current_user = Depends(get_current_user_dependency)
):
    """Criar 12 planos automaticamente (apenas para Unidades) - baseado nas tabelas do Master com percentual de lucro
    🔧 NOVO: Criar planos automaticamente com base em tipo de veículo e coberturas
    Permite Unidade e Master criar
    """
    from server import db as db_instance
    
    # ✅ Apenas Unidades criam planos (Master cria tabelas)
    user_type = current_user.get('user_type')
    if user_type != 'labelview_unidade':
        raise HTTPException(status_code=403, detail="Apenas Unidades podem criar planos")
    
    try:
        body = await request.json()
        tipo_veiculo = body.get('tipo_veiculo')
        taxa_adesao = body.get('taxa_adesao', 0)
        coberturas_principais = body.get('coberturas_principais', [])
        adicionais = body.get('adicionais', [])
        
        logger.info(f"📝 Criando planos automáticos - Tipo: {tipo_veiculo}")
        logger.info(f"   Coberturas principais: {len(coberturas_principais)}")
        logger.info(f"   Adicionais: {len(adicionais)}")
        
        planos_criados = []
        
        # ✅ CORREÇÃO: Definir 12 faixas de FIPE de 10 em 10 mil (igual tabela do Master)
        faixas_fipe = []
        for i in range(12):
            valor_min = i * 10000
            valor_max = (i + 1) * 10000
            faixas_fipe.append({
                'nome': f'Faixa {i+1}',
                'fipe_min': valor_min,
                'fipe_max': valor_max
            })
        
        # ✅ Importar função de busca na tabela do Master
        from tabelas_valores import buscar_valor_na_tabela
        
        # ✅ CRIAR 12 PLANOS (1 por faixa FIPE)
        # Cada plano tem apenas a COBERTURA PRINCIPAL (adicionais são opcionais para o cliente)
        for faixa in faixas_fipe:
            nome_plano = f"{tipo_veiculo} - {faixa['nome']}"
            
            # Calcular FIPE médio da faixa
            fipe_medio = (faixa['fipe_min'] + faixa['fipe_max']) / 2
            
            # ✅ USAR APENAS A COBERTURA PRINCIPAL (normalmente Roubo/Furto)
            # Adicionais são oferecidos ao CLIENTE na cotação
            if not coberturas_principais or len(coberturas_principais) == 0:
                logger.error("❌ Nenhuma cobertura principal definida!")
                continue
            
            # Usar a primeira cobertura principal (geralmente Roubo/Furto)
            cobertura_principal = coberturas_principais[0]
            tipo_cobertura = cobertura_principal['tipo_cobertura']
            percentual_lucro = float(cobertura_principal['percentual'])
            
            # Buscar valor na tabela do Master
            resultado_busca = await buscar_valor_na_tabela(
                db=db_instance,
                tipo_cobertura=tipo_cobertura,
                valor_fipe=fipe_medio,
                tipo_veiculo_assistencia=tipo_veiculo
            )
            
            if resultado_busca.get('success'):
                valor_base_master = float(resultado_busca.get('valor_servico', 0))
                # Aplicar percentual de lucro sobre o valor do Master
                custo_mensal = valor_base_master * (1 + percentual_lucro / 100)
                logger.info(f"      {tipo_cobertura}: R$ {valor_base_master:.2f} + {percentual_lucro}% = R$ {custo_mensal:.2f}")
            else:
                logger.warning(f"      ⚠️ {tipo_cobertura}: Tabela Master não encontrada - usando 0")
                custo_mensal = 0
            
            # ✅ CRIAR PLANO com TODAS as coberturas
            plano_id = str(uuid4())
            plano_data = {
                'id': plano_id,
                'nome': nome_plano,
                'tipo_veiculo': tipo_veiculo,
                'taxa_adesao': taxa_adesao,
                # ✅ CORREÇÃO: Nomes dos campos que o frontend espera
                'valor_fipe_min': faixa['fipe_min'],
                'valor_fipe_max': faixa['fipe_max'],
                'fipe_min': faixa['fipe_min'],  # Manter compatibilidade
                'fipe_max': faixa['fipe_max'],  # Manter compatibilidade
                'custo_mensal': round(custo_mensal, 2),
                'valor_total_mensal': round(custo_mensal, 2),  # ✅ Campo que o frontend usa
                # ✅ Armazenar TODAS as coberturas com seus percentuais
                'coberturas_principais': coberturas_principais,
                'coberturas': coberturas_principais,  # Manter compatibilidade
                'adicionais': adicionais,
                'unidade_id': current_user['id'],
                # ✅ CORREÇÃO: Campo 'ativo' que o frontend espera
                'ativo': True,
                'is_active': True,  # Manter compatibilidade
                'is_blocked': False,
                'created_at': datetime.utcnow(),
                'updated_at': datetime.utcnow(),
                'created_by': current_user["id"]
            }
            
            await db_instance.labelview_planos.insert_one(plano_data)
            planos_criados.append(nome_plano)
            logger.info(f"   ✅ Criado: {nome_plano} (FIPE: R$ {faixa['fipe_min']/1000:.0f}k - R$ {faixa['fipe_max']/1000:.0f}k, Custo: R$ {custo_mensal:.2f}/mês)")
        
        logger.info(f"✅ Total de planos criados: {len(planos_criados)}")
        
        return {
            'success': True,
            'message': f'Planos criados para {tipo_veiculo}',
            'total_planos_criados': len(planos_criados),
            'planos': planos_criados
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Error creating automatic plans: {e}")
        import traceback
        traceback.print_exc()
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.post("/planos")
async def create_plano(
    nome: str,
    current_user = Depends(get_current_user_dependency)
):
    """Criar novo tipo de plano (apenas Unidades)"""
    from server import db as db_instance
    
    # ✅ Apenas Unidades criam planos
    if current_user.get('user_type') != 'labelview_unidade':
        raise HTTPException(status_code=403, detail="Apenas Unidades podem criar planos")
    
    try:
        # Verificar se já existe um plano com esse nome
        existing = await db_instance.labelview_planos.find_one({'nome': nome})
        if existing:
            raise HTTPException(status_code=400, detail="Já existe um plano com esse nome")
        
        plano_data = {
            'id': str(uuid4()),
            'nome': nome,
            'is_active': True,
            'is_blocked': False,
            'created_at': datetime.utcnow(),
            'updated_at': datetime.utcnow(),
            'created_by': current_user["id"]
        }
        
        await db_instance.labelview_planos.insert_one(plano_data)
        
        # Remover _id para retornar
        plano_data.pop('_id', None)
        
        return {
            'success': True,
            'message': 'Plano criado com sucesso',
            'plano': plano_data
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error creating plano: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.put("/planos/{plano_id}")
async def update_plano(
    plano_id: str,
    nome: str,
    current_user = Depends(get_current_user_dependency)
):
    """Atualizar tipo de plano (apenas Unidades)"""
    from server import db as db_instance
    
    # ✅ Apenas Unidades editam planos
    if current_user.get('user_type') != 'labelview_unidade':
        raise HTTPException(status_code=403, detail="Apenas Unidades podem editar planos")
    
    try:
        # Verificar se o plano existe
        plano = await db_instance.labelview_planos.find_one({'id': plano_id})
        if not plano:
            raise HTTPException(status_code=404, detail="Plano não encontrado")
        
        # Verificar se outro plano já usa esse nome
        existing = await db_instance.labelview_planos.find_one({'nome': nome, 'id': {'$ne': plano_id}})
        if existing:
            raise HTTPException(status_code=400, detail="Já existe outro plano com esse nome")
        
        # Atualizar
        result = await db_instance.labelview_planos.update_one(
            {'id': plano_id},
            {'$set': {
                'nome': nome,
                'updated_at': datetime.utcnow()
            }}
        )
        
        if result.modified_count == 0:
            raise HTTPException(status_code=404, detail="Plano não encontrado")
        
        return {
            'success': True,
            'message': 'Plano atualizado com sucesso'
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error updating plano: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.patch("/planos/{plano_id}/block")
async def toggle_block_plano(
    plano_id: str,
    current_user = Depends(get_current_user_dependency)
):
    """Bloquear/desbloquear tipo de plano"""
    from server import db as db_instance
    await verify_labelview_master(current_user["id"])
    
    try:
        plano = await db_instance.labelview_planos.find_one({'id': plano_id})
        if not plano:
            raise HTTPException(status_code=404, detail="Plano não encontrado")
        
        new_status = not plano.get('is_blocked', False)
        
        await db_instance.labelview_planos.update_one(
            {'id': plano_id},
            {'$set': {
                'is_blocked': new_status,
                'updated_at': datetime.utcnow()
            }}
        )
        
        return {
            'success': True,
            'message': f"Plano {'bloqueado' if new_status else 'desbloqueado'} com sucesso",
            'is_blocked': new_status
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error toggling block plano: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.delete("/planos/{plano_id}")
async def delete_plano(
    plano_id: str,
    current_user = Depends(get_current_user_dependency)
):
    """Excluir plano - Unidade pode deletar seus próprios planos"""
    from server import db as db_instance
    
    try:
        # Buscar o plano primeiro para verificar permissão
        plano = await db_instance.labelview_planos.find_one({'id': plano_id})
        
        if not plano:
            raise HTTPException(status_code=404, detail="Plano não encontrado")
        
        # Verificar permissão
        user_type = current_user.get('user_type')
        if user_type == 'labelview_unidade':
            # Unidade só pode deletar seus próprios planos
            if plano.get('unidade_id') != current_user['id']:
                raise HTTPException(status_code=403, detail="Sem permissão para deletar este plano")
        elif user_type == 'labelview_master' or current_user.get('is_labelview_master'):
            # Master pode deletar qualquer plano
            pass
        else:
            raise HTTPException(status_code=403, detail="Sem permissão para deletar planos")
        
        result = await db_instance.labelview_planos.delete_one({'id': plano_id})
        
        return {
            'success': True,
            'message': 'Plano excluído com sucesso'
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error deleting plano: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.post("/planos/limpar-todos")
async def limpar_todos_planos(
    current_user = Depends(get_current_user_dependency)
):
    """Deletar TODOS os planos da unidade - Unidade pode limpar seus próprios planos"""
    from server import db as db_instance
    
    try:
        # Pegar unidade_id do usuário logado
        unidade_id = current_user['id']
        
        # Deletar todos os planos da unidade
        result = await db_instance.labelview_planos.delete_many({'unidade_id': unidade_id})
        
        return {
            'success': True,
            'message': f'{result.deleted_count} planos deletados com sucesso',
            'deleted_count': result.deleted_count
        }
    except Exception as e:
        logger.error(f"Error deleting all planos: {e}")
        raise HTTPException(status_code=500, detail=str(e))


