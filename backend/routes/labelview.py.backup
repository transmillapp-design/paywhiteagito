@labelview_router.patch("/crm/cotacao-to-negociacao/{protecao_id}")
async def mover_para_negociacao(
    protecao_id: str,
    dados: dict,
    current_user = Depends(get_current_user_dependency)
):
    """Mover para Negociação em Proteção (Step 3 - Plano escolhido)"""
    from server import db as db_instance
    
    try:
        # Atualizar proteção existente
        resultado = await db_instance.labelview_crm_protecoes.update_one(
            {'id': protecao_id},
            {
                '$set': {
                    'status': 'negociacao',  # Segunda coluna do funil
                    'plano_nome': dados.get('plano_nome', ''),
                    'plano_valor': dados.get('plano_valor', 0),
                    'adicionais': dados.get('adicionais', []),
                    'valor_total': dados.get('valor_total', 0),
                    'updated_at': datetime.utcnow()
                }
            }
        )
        
        if resultado.modified_count == 0:
            raise HTTPException(status_code=404, detail="Proteção não encontrada")
        
        logger.info(f"✅ Proteção movida para NEGOCIAÇÃO: {protecao_id}")
        
        return {
            'success': True,
            'message': 'Proteção movida para Negociação'
        }
    except Exception as e:
        logger.error(f"❌ Erro ao mover para negociação: {e}")
        raise HTTPException(status_code=500, detail=str(e))


