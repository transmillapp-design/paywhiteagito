# ==================== TABELAS DE VALORES ====================
# Endpoints para gerenciar tabelas de valores de serviços

@labelview_router.post("/tabelas/importar-roubo-furto")
async def importar_roubo_furto_direct(
    request: Request,
    current_user: dict = Depends(get_current_user_dependency)
):
    """Importar valores padrão de Roubo/Furto - DEVE VIR ANTES DA ROTA GENÉRICA"""
    from server import db as db_instance
    
    # Verificar se é master
    user_type = current_user.get('user_type')
    if user_type != 'labelview_master':
        raise HTTPException(status_code=403, detail="Apenas Master pode importar dados")
    
    try:
        # Criar 12 faixas de R$ 10.000 cada
        faixas = []
        for i in range(12):
            valor_min = i * 10000
            valor_max = (i + 1) * 10000
            faixas.append({"min": valor_min, "max": valor_max})
        
        # Valor padrão para Roubo/Furto
        valor_servico = 50.00
        tipo_cobertura = "Roubo/Furto"
        
        # Remover registros antigos
        await db_instance.labelview_tabelas_valores.delete_many({
            "tipo_cobertura": tipo_cobertura
        })
        
        # Criar novos registros
        registros_criados = 0
        for faixa in faixas:
            tabela_id = str(uuid4())
            
            tabela_doc = {
                "id": tabela_id,
                "tipo_cobertura": tipo_cobertura,
                "valor_servico": valor_servico,
                "valor_fipe_min": float(faixa["min"]),
                "valor_fipe_max": float(faixa["max"]),
                "descricao": f"Roubo/Furto - R$ {valor_servico:.2f} (Faixa FIPE: R$ {faixa['min']:,.2f} - R$ {faixa['max']:,.2f})",
                "ativo": True,
                "criado_por": current_user['id'],
                "criado_em": datetime.utcnow(),
                "atualizado_em": datetime.utcnow()
            }
            
            await db_instance.labelview_tabelas_valores.insert_one(tabela_doc)
            registros_criados += 1
        
        return {
            'success': True,
            'message': f'Roubo/Furto importado com sucesso! {registros_criados} registros criados.',
            'registros_criados': registros_criados
        }
        
    except Exception as e:
        logger.error(f"Erro ao importar Roubo/Furto: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.post("/tabelas/{tipo_cobertura}")
async def criar_tabela_valor_endpoint(
    tipo_cobertura: str,
    valor_servico: float = Form(...),
    valor_fipe_min: float = Form(...),
    valor_fipe_max: float = Form(...),
    descricao: str = Form(""),
    tipo_veiculo_assistencia: Optional[str] = Form(None),
    current_user: dict = Depends(get_current_user_dependency)
):
    """Criar nova entrada na tabela de valores"""
    from server import db as db_instance
    import sys
    sys.path.append('/app/backend')
    from tabelas_valores import criar_tabela_valor
    
    # Verificar se é master ou unidade
    user_type = current_user.get('user_type')
    if user_type not in ['labelview_master', 'labelview_unidade']:
        raise HTTPException(status_code=403, detail="Apenas Master e Unidade podem criar tabelas de valores")
    
    dados = {
        "valor_servico": valor_servico,
        "valor_fipe_min": valor_fipe_min,
        "valor_fipe_max": valor_fipe_max,
        "descricao": descricao,
        "tipo_veiculo_assistencia": tipo_veiculo_assistencia
    }
    
    resultado = await criar_tabela_valor(
        db=db_instance,
        tipo_cobertura=tipo_cobertura,
        dados=dados,
        criado_por=current_user['id']
    )
    
    if not resultado.get('success'):
        raise HTTPException(status_code=400, detail=resultado.get('message'))
    
    return resultado


@labelview_router.get("/tabelas/{tipo_cobertura:path}")
async def listar_tabelas_endpoint(
    tipo_cobertura: str,
    current_user: dict = Depends(get_current_user_dependency)
):
    """Listar todas as tabelas de um tipo específico - aceita / no nome"""
    from server import db as db_instance
    import sys
    sys.path.append('/app/backend')
    from tabelas_valores import listar_tabelas_por_tipo
    
    logger.info(f"📋 Listando tabelas do tipo: '{tipo_cobertura}'")
    
    # Converter underscore para slash se necessário (compatibilidade frontend)
    if "_" in tipo_cobertura and "/" not in tipo_cobertura:
        # Roubo_Furto -> Roubo/Furto
        tipo_cobertura = tipo_cobertura.replace("_", "/")
        logger.info(f"📋 Convertido para: '{tipo_cobertura}'")
    
    # Verificar se é usuário labelview
    user_type = current_user.get('user_type')
    if not user_type or not user_type.startswith('labelview_'):
        raise HTTPException(status_code=403, detail="Acesso negado")
    
    resultado = await listar_tabelas_por_tipo(db=db_instance, tipo_cobertura=tipo_cobertura)
    
    logger.info(f"📋 Resultado: success={resultado.get('success')}, total={resultado.get('total', 0)}")
    
    if not resultado.get('success'):
        raise HTTPException(status_code=400, detail=resultado.get('message'))
    
    return resultado


