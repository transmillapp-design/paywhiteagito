# Endpoint de importação movido para cima (antes da rota genérica)


@labelview_router.get("/filtros/unidades")
async def get_filtros_unidades(current_user: dict = Depends(get_current_user_dependency)):
    """Listar unidades para filtros"""
    from server import db as db_instance
    
    try:
        unidades = await db_instance.users.find(
            {'user_type': 'labelview_unidade'},
            {'id': 1, 'nome_fantasia': 1, 'email': 1}
        ).to_list(length=None)
        
        # Formatar resposta
        result = []
        for u in unidades:
            result.append({
                'id': u.get('id'),
                'nome': u.get('nome_fantasia', 'Sem nome'),
                'email': u.get('email')
            })
        
        return {
            'success': True,
            'unidades': result
        }
    except Exception as e:
        logger.error(f"Erro ao listar unidades para filtros: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.get("/notifications/unread-count")
async def get_unread_notifications_count(current_user: dict = Depends(get_current_user_dependency)):
    """Retornar contagem de notificações não lidas"""
    try:
        from server import db as db_instance
        # Por enquanto retorna 0 (funcionalidade de notificações será implementada depois)
        return {
            'success': True,
            'unread_count': 0
        }
    except Exception as e:
        logger.error(f"Erro ao buscar notificações: {str(e)}")
        return {
            'success': True,
            'unread_count': 0
        }

