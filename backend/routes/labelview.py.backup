    except Exception as e:
        logger.error(f"Error updating tipo fornecedor: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.patch("/tipos-fornecedor/{tipo_id}/block")
async def toggle_block_tipo_fornecedor(
    tipo_id: str,
    current_user: dict = Depends(get_current_user_dependency)
):
    """Bloquear/desbloquear tipo de fornecedor"""
    from server import db as db_instance
    
    # Apenas Master
    user_type = current_user.get('user_type')
    if user_type != 'labelview_master':
        raise HTTPException(status_code=403, detail="Apenas Master pode bloquear tipos")
    
    try:
        tipo = await db_instance.labelview_tipos_fornecedor.find_one({'id': tipo_id})
        if not tipo:
            raise HTTPException(status_code=404, detail="Tipo não encontrado")
        
        new_status = not tipo.get('is_blocked', False)
        
        await db_instance.labelview_tipos_fornecedor.update_one(
            {'id': tipo_id},
            {'$set': {
                'is_blocked': new_status,
                'updated_at': datetime.utcnow()
            }}
        )
        
        return {
            'success': True,
            'message': f"Tipo {'bloqueado' if new_status else 'desbloqueado'} com sucesso",
            'is_blocked': new_status
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error toggling block tipo fornecedor: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.delete("/tipos-fornecedor/{tipo_id}")
async def delete_tipo_fornecedor(
    tipo_id: str,
    current_user: dict = Depends(get_current_user_dependency)
):
    """Deletar tipo de fornecedor"""
    from server import db as db_instance
    
    # 🔧 CORREÇÃO: Master e Unidade podem deletar tipos
    user_type = current_user.get('user_type')
    user_id = current_user.get('id')
    
    logger.info(f"🗑️ DELETE tipo fornecedor {tipo_id} - User: {user_id} ({user_type})")
    
    try:
        # Buscar o tipo primeiro para verificar permissões
        tipo = await db_instance.labelview_tipos_fornecedor.find_one({'id': tipo_id})
        
        if not tipo:
            raise HTTPException(status_code=404, detail="Tipo não encontrado")
        
        # Master pode deletar qualquer tipo
        # Unidade pode deletar apenas seus próprios tipos
        if user_type == 'labelview_master':
            logger.info(f"✅ Master pode deletar qualquer tipo")
        elif user_type == 'labelview_unidade':
            if tipo.get('created_by') != user_id and tipo.get('unidade_id') != user_id:
                logger.warning(f"❌ Unidade tentando deletar tipo de outra unidade")
                raise HTTPException(status_code=403, detail="Você só pode deletar seus próprios tipos")
            logger.info(f"✅ Unidade deletando seu próprio tipo")
        else:
            logger.warning(f"❌ {user_type} não tem permissão para deletar tipos")
            raise HTTPException(status_code=403, detail="Você não tem permissão para deletar tipos")
        
        # Deletar o tipo
        result = await db_instance.labelview_tipos_fornecedor.delete_one({'id': tipo_id})
        
        if result.deleted_count == 0:
            raise HTTPException(status_code=404, detail="Tipo não encontrado")
        
        logger.info(f"✅ Tipo {tipo_id} deletado com sucesso")
        
        return {
            'success': True,
            'message': 'Tipo excluído com sucesso'
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Error deleting tipo fornecedor: {e}")
        raise HTTPException(status_code=500, detail=str(e))


# ============================================
# FORNECEDORES
# ============================================

@labelview_router.get("/fornecedores")
async def get_fornecedores(
    current_user: dict = Depends(get_current_user_dependency)
):
    """
    Listar fornecedores baseado no tipo de usuário
    Master vê todos, Unidade vê seus fornecedores, Regional vê seus fornecedores
    """
    from server import db as db_instance
    
    user_type = current_user.get('user_type')
    user_id = current_user.get('id')
    
    try:
        # Filtrar baseado no tipo de usuário
        query = {}
        
        if user_type == 'labelview_master':
            # Master vê todos os fornecedores
            query = {'user_type': 'labelview_fornecedor'}
        elif user_type in ['labelview_unidade', 'labelview_regional']:
            # Unidade e Regional veem apenas fornecedores que cadastraram
            query = {
                'user_type': 'labelview_fornecedor',
                'fornecedor_de': user_id
            }
        else:
            raise HTTPException(status_code=403, detail="Acesso negado")
        
        fornecedores = await db_instance.users.find(query).to_list(length=1000)
        
        # Remover _id e password_hash
        for fornecedor in fornecedores:
            fornecedor.pop('_id', None)
            fornecedor.pop('password_hash', None)
        
        return {
            'success': True,
            'fornecedores': fornecedores,
            'total': len(fornecedores)
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error fetching fornecedores: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.post("/fornecedores")
async def create_fornecedor(
    request: Request,
    # Dados da Empresa (PJ)
    nome_fantasia: str = Form(...),
    razao_social: str = Form(...),
    cnpj: str = Form(...),
    telefone: str = Form(...),
    email: str = Form(...),
    
    # Tipo de Serviço e Área de Atendimento
    tipo_servico_id: str = Form(...),
    area_atendimento: str = Form(...),  # 'nacional', 'estadual', 'cidade'
    area_atendimento_estado: Optional[str] = Form(None),  # Se estadual ou cidade
    area_atendimento_cidade: Optional[str] = Form(None),  # Se cidade
    
    # Responsável/Sócio Administrador
    responsavel_nome: str = Form(...),
    responsavel_cpf: str = Form(...),
    responsavel_email: str = Form(...),
    responsavel_telefone: str = Form(...),
    
    # Endereço
    cep: str = Form(...),
    street: str = Form(...),
    number: str = Form(...),
    neighborhood: str = Form(...),
    city: str = Form(...),
    state: str = Form(...),
    complement: Optional[str] = Form(''),
    
    # PIX
    pix_key: str = Form(...),
    pix_key_type: str = Form(...),
    
    # Cores e Logo
    cor_primaria: Optional[str] = Form('#1a59ad'),
    cor_secundaria: Optional[str] = Form('#2fa31c'),
    logo: Optional[UploadFile] = File(None),
    
    # Documentos
    contrato_social: Optional[UploadFile] = File(None),
    doc_cnpj: Optional[UploadFile] = File(None),
    
    current_user: dict = Depends(get_current_user_dependency)
):
    """
    Criar novo fornecedor com conta Transmill
    Fornecedor fica vinculado a quem cadastra (Master, Unidade ou Regional)
    """
    from server import db as db_instance
    import secrets
    import string
    
    # Permitir Master, Unidade e Regional
    user_type = current_user.get('user_type')
    if user_type not in ['labelview_master', 'labelview_unidade', 'labelview_regional']:
        raise HTTPException(status_code=403, detail="Apenas Master, Unidade e Regional podem cadastrar fornecedores")
    
    try:
        # Verificar se email já existe
        existing_user = await db_instance.users.find_one({'email': email})
        if existing_user:
            raise HTTPException(status_code=400, detail="Email já cadastrado no sistema")
        
        # Gerar senha provisória
        def generate_temp_password():
            chars = string.ascii_letters + string.digits
            return ''.join(secrets.choice(chars) for _ in range(12))
        
        temp_password = generate_temp_password()
        password_hash = bcrypt.hash(temp_password)
        
        fornecedor_id = str(uuid4())
        
        # Upload de logo para Cloudinary
        logo_url = None
        if logo:
            logo_content = await logo.read()
            logo_url = await upload_file_to_cloudinary(
                file_content=logo_content,
                filename=f"logo_{fornecedor_id}_{logo.filename}",
                folder=f"labelview/fornecedores/{fornecedor_id}",
                resource_type="image"
            )
        
        # Upload de documentos
        contrato_social_url = None
        if contrato_social:
            cs_content = await contrato_social.read()
            contrato_social_url = await upload_file_to_cloudinary(
                file_content=cs_content,
                filename=f"contrato_social_{fornecedor_id}_{contrato_social.filename}",
                folder=f"labelview/fornecedores/{fornecedor_id}",
                resource_type="raw"
            )
        
        doc_cnpj_url = None
        if doc_cnpj:
            doc_content = await doc_cnpj.read()
            doc_cnpj_url = await upload_file_to_cloudinary(
                file_content=doc_content,
                filename=f"doc_cnpj_{fornecedor_id}_{doc_cnpj.filename}",
                folder=f"labelview/fornecedores/{fornecedor_id}",
                resource_type="raw"
            )
        
        # Determinar vínculo (fornecedor_de) e unidade_id
        fornecedor_de = current_user['id']  # Vinculado a quem cadastrou
        
        # 🔧 CORREÇÃO: Determinar unidade_id para identidade visual
        unidade_id = None
        if user_type == 'labelview_unidade':
            unidade_id = current_user['id']  # Se cadastrado por unidade, é ela mesma
        elif user_type == 'labelview_regional':
            # Regional tem unidade_id
            unidade_id = current_user.get('unidade_id')
        # Se Master cadastrou, fornecedor não terá unidade específica (usa default)
        
        # Criar usuário no Transmill
        user_doc = {
            'id': fornecedor_id,
            'email': email,
            'password_hash': password_hash,
            'temporary_password': temp_password,
            'full_name': nome_fantasia,
            'phone': telefone,
            'user_type': 'labelview_fornecedor',
            'is_active': True,
            'is_blocked': False,
            'must_change_password': True,
            'profile_complete': True,
            'balance': 0.0,
            'cashback_balance': 0.0,
            
            # Dados do fornecedor (PJ)
            'nome_fantasia': nome_fantasia,
            'razao_social': razao_social,
            'cnpj': cnpj,
            'telefone': telefone,
            'logo_url': logo_url,
            'cor_primaria': cor_primaria,
            'cor_secundaria': cor_secundaria,
            
            # Tipo de Serviço e Área
            'tipo_servico_id': tipo_servico_id,
            'area_atendimento': area_atendimento,
            'area_atendimento_estado': area_atendimento_estado,
            'area_atendimento_cidade': area_atendimento_cidade,
            
            # Responsável
            'responsavel_nome': responsavel_nome,
            'responsavel_cpf': responsavel_cpf,
            'responsavel_email': responsavel_email,
            'responsavel_telefone': responsavel_telefone,
            
            # Endereço
            'cep': cep,
            'street': street,
            'number': number,
            'neighborhood': neighborhood,
            'city': city,
            'state': state,
            'complement': complement,
            
            # PIX
            'pix_key': pix_key,
            'pix_key_type': pix_key_type,
            
            # Documentos
            'contrato_social_url': contrato_social_url,
            'doc_cnpj_url': doc_cnpj_url,
            
            # Vínculo
            'fornecedor_de': fornecedor_de,  # ID de quem cadastrou
            'fornecedor_de_tipo': user_type,  # Tipo de quem cadastrou
            'unidade_id': unidade_id,  # ID da unidade para identidade visual
            
            'created_at': datetime.utcnow(),
            'updated_at': datetime.utcnow()
        }
        
        await db_instance.users.insert_one(user_doc)
        
        logger.info(f"✅ Fornecedor criado: {nome_fantasia} (Email: {email})")
        
        return {
            'success': True,
            'message': 'Fornecedor criado com sucesso',
            'fornecedor_id': fornecedor_id,
            'credentials': {
                'email': email,
                'temporary_password': temp_password
            }
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error creating fornecedor: {e}")
        import traceback
        traceback.print_exc()
        raise HTTPException(status_code=500, detail=str(e))


