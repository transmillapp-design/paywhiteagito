@labelview_router.post("/crm/cotacao-to-lead")
async def criar_lead_de_cotacao(
    dados: dict,
    current_user = Depends(get_current_user_dependency)
):
    """Criar lead no CRM a partir da cotação (Step 1 - CPF digitado)"""
    from server import db as db_instance
    
    try:
        # Extrair dados da hierarquia do usuário
        unidade_id = current_user.get('unidade_id') or current_user.get('id') if current_user.get('user_type') == 'labelview_unidade' else None
        regional_id = current_user.get('regional_id') or current_user.get('id') if current_user.get('user_type') == 'labelview_regional' else None
        consultor_id = current_user.get('id') if current_user.get('user_type') == 'labelview_consultor' else None
        
        # Criar lead
        novo_lead = {
            'id': str(uuid4()),
            'name': dados.get('nome', ''),
            'cpf': dados.get('cpf', ''),
            'email': dados.get('email', ''),
            'phone': dados.get('telefone', ''),
            'source': 'cotacao_online',
            'status': 'ativo',
            'unidade_id': unidade_id,
            'regional_id': regional_id,
            'consultor_id': consultor_id,
            'created_at': datetime.utcnow(),
            'updated_at': datetime.utcnow(),
            'created_by': current_user['id'],
            'cotacao_temp_id': dados.get('cotacao_temp_id')  # Link com cotação
        }
        
        await db_instance.labelview_crm_leads.insert_one(novo_lead)
        novo_lead.pop('_id', None)
        
        logger.info(f"✅ Lead criado no CRM: {novo_lead['name']} - CPF: {novo_lead['cpf']}")
        
        return {
            'success': True,
            'message': 'Lead criado no CRM',
            'lead': novo_lead
        }
    except Exception as e:
        logger.error(f"❌ Erro ao criar lead de cotação: {e}")
        raise HTTPException(status_code=500, detail=str(e))


