# ============================================
# UNIDADES
# ============================================

@labelview_router.get("/unidades/{unidade_id}")
async def get_unidade_by_id(
    unidade_id: str,
    current_user: dict = Depends(get_current_user_dependency)
):
    """
    🔧 NOVO: Buscar dados de uma unidade específica por ID
    Usado por Regionais e Consultores para carregar identidade visual da unidade
    """
    try:
        logger.info(f"📥 GET /unidades/{unidade_id} - Buscando unidade específica")
        logger.info(f"   Solicitante: {current_user.get('email')} ({current_user.get('user_type')})")
        
        # Buscar unidade no banco
        unidade = await db.users.find_one({
            'id': unidade_id,
            'user_type': 'labelview_unidade'
        })
        
        if not unidade:
            logger.warning(f"❌ Unidade {unidade_id} não encontrada")
            raise HTTPException(status_code=404, detail="Unidade não encontrada")
        
        logger.info(f"✅ Unidade encontrada: {unidade.get('nome_fantasia')}")
        
        # Retornar dados da unidade (sem senha)
        unidade_data = {
            'id': unidade.get('id'),
            'nome_fantasia': unidade.get('nome_fantasia'),
            'email': unidade.get('email'),
            'logo_url': unidade.get('logo_url', ''),
            'cor_primaria': unidade.get('cor_primaria', '#1a59ad'),
            'cor_secundaria': unidade.get('cor_secundaria', '#2fa31c'),
            'phone': unidade.get('phone', ''),
            'cnpj': unidade.get('cnpj', ''),
            'address': unidade.get('address', ''),
            'city': unidade.get('city', ''),
            'state': unidade.get('state', '')
        }
        
        return unidade_data
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erro ao buscar unidade: {e}")
        raise HTTPException(status_code=500, detail=f"Erro ao buscar unidade: {str(e)}")

@labelview_router.get("/unidades")
async def get_unidades(
    current_user = Depends(get_current_user_dependency)
):
    """Listar unidades"""
    from server import db as db_instance
    
    await verify_labelview_master(current_user["id"])
    
    try:
        # Buscar unidades na coleção users
        unidades = await db_instance.users.find({'user_type': 'labelview_unidade'}).to_list(length=1000)
        
        # Formatar resposta
        unidades_list = []
        for unidade in unidades:
            unidade.pop('_id', None)
            unidade.pop('password_hash', None)  # Não expor hash de senha
            
            # Retornar temporary_password apenas se ainda não trocou a senha
            if not unidade.get('must_change_password', False):
                unidade.pop('temporary_password', None)
            
            # Garantir que name está presente (mapeado de nome_fantasia)
            if 'nome_fantasia' in unidade and not unidade.get('name'):
                unidade['name'] = unidade['nome_fantasia']
            
            unidades_list.append(unidade)
        
        return {
            'success': True,
            'unidades': unidades_list,
            'total': len(unidades_list)
        }
    except Exception as e:
        logger.error(f"Error fetching unidades: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.post("/unidades")
async def create_unidade(
    # Dados da Empresa
    nome_fantasia: str = Form(...),
    razao_social: str = Form(...),
    cnpj: str = Form(...),
    inscricao_municipal: Optional[str] = Form(None),
    inscricao_estadual: Optional[str] = Form(None),
    telefone: Optional[str] = Form(None),
    whatsapp: Optional[str] = Form(None),
    
    # Dados do Responsável
    responsavel_nome: str = Form(...),
    responsavel_cpf: str = Form(...),
    responsavel_email: Optional[str] = Form(None),
    responsavel_whatsapp: Optional[str] = Form(None),
    
    # Dados PIX
    pix_key: str = Form(...),
    pix_key_type: str = Form(...),
    
    # Identidade Visual
    logo: Optional[UploadFile] = File(None),
    cor_primaria: str = Form(...),
    cor_secundaria: str = Form(...),
    
    # Endereço
    cep: Optional[str] = Form(None),
    address: Optional[str] = Form(None),
    number: Optional[str] = Form(None),
    complement: Optional[str] = Form(None),
    neighborhood: Optional[str] = Form(None),
    city: Optional[str] = Form(None),
    state: Optional[str] = Form(None),
    
    # Documentos
    contrato_social: Optional[UploadFile] = File(None),
    doc_cnpj: Optional[UploadFile] = File(None),
    rg_front: Optional[UploadFile] = File(None),
    rg_back: Optional[UploadFile] = File(None),
    
    # Dados de Acesso (opcionais - gerados se não fornecidos)
    email: Optional[str] = Form(None),
    password: Optional[str] = Form(None),
    
    current_user: dict = Depends(get_current_user_dependency)
):
    """Criar nova unidade Labelview"""
    # Importar db dentro da função para evitar circular import
    from server import db as db_instance
    
    await verify_labelview_master(current_user["id"])
    
    try:
        logger.info(f"📋 Criando nova unidade: {nome_fantasia}")
        
        # Gerar ID único para a unidade
        unidade_id = str(uuid4())
        
        # Processar logo - Upload para Cloudinary
        logo_url = None
        if logo and logo.filename:
            logger.info(f"🖼️ Fazendo upload da logo para Cloudinary...")
            logo_content = await logo.read()
            logo_filename = f"logo_unidade_{unidade_id}"
            logo_url = await upload_file_to_cloudinary(
                file_content=logo_content,
                filename=logo_filename,
                folder="labelview/unidades/logos",
                resource_type="image"
            )
            if logo_url:
                logger.info(f"✅ Logo salva no Cloudinary: {logo_url}")
            else:
                logger.warning(f"⚠️ Falha ao fazer upload da logo")
        
        # Processar documentos - Upload para Cloudinary
        doc_urls = {}
        docs = {
            'contrato_social': contrato_social,
            'doc_cnpj': doc_cnpj,
            'rg_front': rg_front,
            'rg_back': rg_back
        }
        
        for doc_name, doc_file in docs.items():
            if doc_file and doc_file.filename:
                logger.info(f"📄 Fazendo upload do documento {doc_name} para Cloudinary...")
                doc_content = await doc_file.read()
                doc_filename = f"{doc_name}_unidade_{unidade_id}"
                doc_url = await upload_file_to_cloudinary(
                    file_content=doc_content,
                    filename=doc_filename,
                    folder="labelview/unidades/documentos",
                    resource_type="raw"  # raw para documentos PDF, etc
                )
                if doc_url:
                    doc_urls[doc_name] = doc_url
                    logger.info(f"✅ Documento {doc_name} salvo no Cloudinary: {doc_url}")
                else:
                    logger.warning(f"⚠️ Falha ao fazer upload do documento {doc_name}")
        
        # Gerar credenciais de acesso se não fornecidas
        if not email:
            # Gerar email único baseado no CNPJ
            cnpj_numbers = ''.join(filter(str.isdigit, cnpj))
            email = f"unidade.{cnpj_numbers}@labelview.agitomil.com"
        
        # Gerar senha provisória se não fornecida
        temporary_password = password if password else "SenhaProvisoria2024!"
        password_hash = bcrypt.hash(temporary_password)
        
        logger.info(f"🔑 Credenciais geradas - Email: {email}")
        
        # Criar usuário na coleção users
        user_data = {
            'id': unidade_id,
            'email': email,
            'password_hash': password_hash,
            'temporary_password': temporary_password,  # Salvar senha provisória para visualização
            'full_name': nome_fantasia,
            'phone': telefone or '',
            'user_type': 'labelview_unidade',
            'is_labelview_master': False,
            'is_active': True,
            'is_blocked': False,
            'must_change_password': True,
            'profile_complete': True,
            'balance': 0.0,
            'cashback_balance': 0.0,
            'created_at': datetime.utcnow().isoformat(),
            'updated_at': datetime.utcnow().isoformat(),
            
            # Dados específicos da Unidade Labelview
            'nome_fantasia': nome_fantasia,
            'razao_social': razao_social,
            'cnpj': cnpj,
            'inscricao_municipal': inscricao_municipal or '',
            'inscricao_estadual': inscricao_estadual or '',
            'telefone': telefone or '',
            'whatsapp': whatsapp or '',
            
            # Responsável
            'responsavel_nome': responsavel_nome,
            'responsavel_cpf': responsavel_cpf,
            'responsavel_email': responsavel_email,
            'responsavel_whatsapp': responsavel_whatsapp or '',
            
            # PIX
            'pix_key': pix_key,
            'pix_key_type': pix_key_type,
            
            # Identidade Visual
            'logo_url': logo_url,
            'cor_primaria': cor_primaria,
            'cor_secundaria': cor_secundaria,
            
            # Endereço
            'cep': cep or '',
            'address': address or '',
            'street': address or '',  # Alias para compatibilidade
            'number': number or '',
            'complement': complement or '',
            'neighborhood': neighborhood or '',
            'city': city or '',
            'state': state or '',
            
            # Documentos
            'contrato_social_url': doc_urls.get('contrato_social'),
            'doc_cnpj_url': doc_urls.get('doc_cnpj'),
            'rg_front_url': doc_urls.get('rg_front'),
            'rg_back_url': doc_urls.get('rg_back'),
            
            # Admin fields para compatibilidade
            'admin_name': responsavel_nome,
            'admin_cpf': responsavel_cpf,
            'admin_email': responsavel_email,
            
            # Referral Transmill - Unidade criada pelo Master
            'referred_by': current_user["id"],  # Master que criou esta unidade
            'referral_code': f"UNIT_{unidade_id[:8].upper()}",  # Código único da unidade
            'referral_code_used': current_user.get('referral_code', ''),  # Código de quem indicou
        }
        
        # Inserir usuário
        logger.info(f"📝 Pronto para inserir no banco - user_data tem {len(user_data)} campos")
        logger.info(f"🔑 user_data keys: {list(user_data.keys())}")
        
        insert_result = await db_instance.users.insert_one(user_data)
        logger.info(f"✅ Insert executado - MongoDB _id: {insert_result.inserted_id}")
        
        # Verificar se realmente salvou
        verify = await db_instance.users.find_one({'id': unidade_id})
        if verify:
            logger.info(f"✅ Verificado: Usuário está no banco! Email: {verify.get('email')}")
        else:
            logger.error(f"❌ CRÍTICO: Insert retornou OK mas usuário NÃO está no banco!")
        
        logger.info(f"✅ Usuário criado com sucesso: {unidade_id}")
        
        # Retornar resposta
        return {
            'success': True,
            'message': 'Unidade criada com sucesso',
            'unidade_id': unidade_id,
            'credentials': {
                'email': email,
                'password': temporary_password
            }
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erro ao criar unidade: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"Erro ao criar unidade: {str(e)}")


@labelview_router.delete("/unidades/{unidade_id}")
async def delete_unidade(
    unidade_id: str,
    current_user: dict = Depends(get_current_user_dependency)
):
    """Deletar unidade"""
    from server import db as db_instance
    
    await verify_labelview_master(current_user["id"])
    
    try:
        logger.info(f"🗑️ Deletando unidade: {unidade_id}")
        
        # Verificar se unidade existe
        unidade = await db_instance.users.find_one({'id': unidade_id, 'user_type': 'labelview_unidade'})
        if not unidade:
            raise HTTPException(status_code=404, detail="Unidade não encontrada")
        
        # Deletar unidade
        result = await db_instance.users.delete_one({'id': unidade_id})
        
        if result.deleted_count > 0:
            logger.info(f"✅ Unidade deletada com sucesso: {unidade_id}")
            return {
                'success': True,
                'message': 'Unidade deletada com sucesso'
            }
        else:
            raise HTTPException(status_code=404, detail="Unidade não encontrada")
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erro ao deletar unidade: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"Erro ao deletar unidade: {str(e)}")


