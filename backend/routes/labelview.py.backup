class TipoFornecedorCreate(BaseModel):
    tipo_servico: str


@labelview_router.post("/tipos-fornecedor")
async def create_tipo_fornecedor(
    tipo: TipoFornecedorCreate,
    current_user: dict = Depends(get_current_user_dependency)
):
    """Criar novo tipo de fornecedor"""
    from server import db as db_instance
    
    # Permitir Master e Unidade
    user_type = current_user.get('user_type')
    if user_type not in ['labelview_master', 'labelview_unidade']:
        raise HTTPException(status_code=403, detail="Apenas Master e Unidade podem criar tipos de fornecedor")
    
    try:
        # Verificar se já existe
        existing = await db_instance.labelview_tipos_fornecedor.find_one({
            'tipo_servico': tipo.tipo_servico
        })
        
        if existing:
            raise HTTPException(status_code=400, detail="Tipo de fornecedor já existe")
        
        tipo_id = str(uuid4())
        tipo_doc = {
            'id': tipo_id,
            'tipo_servico': tipo.tipo_servico,
            'is_blocked': False,
            'created_by': current_user['id'],
            'created_at': datetime.utcnow(),
            'updated_at': datetime.utcnow()
        }
        
        await db_instance.labelview_tipos_fornecedor.insert_one(tipo_doc)
        
        tipo_doc.pop('_id', None)
        
        return {
            'success': True,
            'message': 'Tipo de fornecedor criado com sucesso',
            'tipo': tipo_doc
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error creating tipo fornecedor: {e}")
        raise HTTPException(status_code=500, detail=str(e))


