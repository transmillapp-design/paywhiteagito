# ============================================
# DASHBOARD/STATS
# ============================================

@labelview_router.get("/dashboard/stats")
async def get_dashboard_stats(
    current_user = Depends(get_current_user_dependency)
):
    """Estatísticas do dashboard"""
    from server import db as db_instance
    # Não precisa ser master - Unidade, Regional e Master podem acessar
    
    try:
        # Clientes ativos
        total_clients = await db_instance.labelview_clients.count_documents({'is_active': True})
        
        # Solicitações pendentes
        pending_requests = await db_instance.labelview_service_requests.count_documents({'status': 'pending'})
        
        # Rastreadores disponíveis
        available_trackers = await db_instance.labelview_trackers.count_documents({'status': 'available'})
        
        # Fornecedores ativos
        active_providers = await db_instance.labelview_providers.count_documents({'is_active': True})
        
        # Consultores ativos
        active_consultants = await db_instance.labelview_consultants.count_documents({'is_active': True})
        
        # Receita do mês atual
        from datetime import datetime as dt
        current_month = dt.utcnow().strftime('%Y-%m')
        month_payments = await db_instance.labelview_payments.find({
            'reference_month': current_month
        }).to_list(length=10000)
        
        month_revenue = sum(p.get('labelview_amount', 0) for p in month_payments)
        
        return {
            'success': True,
            'stats': {
                'total_clients': total_clients,
                'pending_requests': pending_requests,
                'available_trackers': available_trackers,
                'active_providers': active_providers,
                'active_consultants': active_consultants,
                'month_revenue': month_revenue,
                'total_payments': len(month_payments)
            }
        }
    except Exception as e:
        logger.error(f"Error fetching dashboard stats: {e}")
        raise HTTPException(status_code=500, detail=str(e))


