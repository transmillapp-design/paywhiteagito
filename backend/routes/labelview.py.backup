labelview_router = APIRouter(prefix="/api/labelview", tags=["labelview"])

@labelview_router.get("/version-check")
async def version_check():
    """Verificar se API está funcionando"""
    import os
    from datetime import datetime
    
    # Ler versão do arquivo
    try:
        with open('/app/VERSION.txt', 'r') as f:
            lines = f.readlines()
            version = lines[0].strip() if len(lines) > 0 else 'v2.1.1'
            build_date = lines[1].strip() if len(lines) > 1 else '2025-01-02 02:30:00'
            last_change = lines[2].strip() if len(lines) > 2 else 'Versão inicial'
    except:
        version = 'v2.1.1'
        build_date = '2025-01-02 02:30:00'
        last_change = 'Arquivo VERSION.txt não encontrado'
    
    cloudinary_configured = bool(os.environ.get('CLOUDINARY_CLOUD_NAME') and os.environ.get('CLOUDINARY_API_KEY'))
    
    return {
        'success': True,
        'version': version,
        'build_date': build_date,
        'last_change': last_change,
        'timestamp': datetime.utcnow().isoformat(),
        'environment': {
            'cloudinary_configured': cloudinary_configured,
            'has_debug_logs': True
        }
    }


