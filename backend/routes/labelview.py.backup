@labelview_router.post("/regionais")
async def create_regional(
    # Dados Básicos
    nome: str = Form(...),
    email_regional: Optional[str] = Form(None),
    password_regional: Optional[str] = Form(None),
    telefone: str = Form(...),
    cpf: Optional[str] = Form(None),
    
    # Vínculo Hierárquico REMOVIDO: unidade_id vem automaticamente do current_user
    
    # Comissão
    comissao_mensalidade_tipo: str = Form("percentual"),  # percentual ou valor
    comissao_mensalidade_valor: float = Form(0.0),
    
    # Dados Pessoa Jurídica (opcional)
    razao_social: Optional[str] = Form(None),
    cnpj: Optional[str] = Form(None),
    
    current_user: dict = Depends(get_current_user_dependency)
):
    """Criar nova regional"""
    from server import db as db_instance
    try:
        logger.info(f"📋 Criando nova regional: {nome}")
        
        # Validar hierarquia: apenas Unidade pode criar Regional
        if current_user.get('user_type') != 'labelview_unidade':
            raise HTTPException(status_code=403, detail="Apenas Unidades podem criar Regionais")
        
        # unidade_id DEVE ser o ID da Unidade logada
        unidade_id_real = current_user.get('id')
        
        logger.info(f"🏢 Regional será vinculado à Unidade: {unidade_id_real}")
        
        # Gerar ID único
        regional_id = str(uuid4())
        
        # Gerar credenciais se não fornecidas
        if not email_regional:
            email_regional = f"regional.{regional_id[:8]}@labelview.agitomil.com"
        
        temporary_password = password_regional if password_regional else "SenhaProvisoria2024!"
        password_hash = bcrypt.hash(temporary_password)
        
        logger.info(f"🔑 Credenciais geradas - Email: {email_regional}")
        
        # Criar usuário na coleção users
        user_data = {
            'id': regional_id,
            'email': email_regional,
            'password_hash': password_hash,
            'temporary_password': temporary_password,
            'full_name': nome,
            'phone': telefone or '',
            'user_type': 'labelview_regional',
            'is_labelview_master': False,
            'is_active': True,
            'is_blocked': False,
            'must_change_password': True,
            'profile_complete': True,
            'balance': 0.0,
            'cashback_balance': 0.0,
            'created_at': datetime.utcnow().isoformat(),
            'updated_at': datetime.utcnow().isoformat(),
            
            # Dados específicos da Regional
            'nome': nome,
            'telefone': telefone or '',
            'cpf': cpf or '',
            'razao_social': razao_social or '',
            'cnpj': cnpj or '',
            
            # Hierarquia Labelview
            'unidade_id': unidade_id_real,  # ID da Unidade que está criando
            
            # Comissão
            'comissao_mensalidade_tipo': comissao_mensalidade_tipo,
            'comissao_mensalidade_valor': comissao_mensalidade_valor,
            
            # Referral Transmill - Regional criado pela Unidade
            'referred_by': current_user['id'],  # Unidade que criou
            'referral_code': f"REG_{regional_id[:8].upper()}",
            'referral_code_used': current_user.get('referral_code', ''),  # Código de quem indicou
        }
        
        # Inserir usuário
        await db_instance.users.insert_one(user_data)
        logger.info(f"✅ Regional criado com sucesso: {regional_id}")
        
        return {
            'success': True,
            'message': 'Regional criado com sucesso',
            'regional_id': regional_id,
            'credentials': {
                'email': email_regional,
                'password': temporary_password
            }
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erro ao criar regional: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"Erro ao criar regional: {str(e)}")


# ============================================
# CONSULTORES
# ============================================

@labelview_router.get("/consultores")
async def get_consultores(
    unidade_id: Optional[str] = None,  # 🔧 NOVO: Filtro por unidade
    regional_id: Optional[str] = None,  # 🔧 NOVO: Filtro por regional
    current_user: dict = Depends(get_current_user_dependency)
):
    """Listar consultores com filtros opcionais"""
    from server import db as db_instance
    try:
        # Buscar consultores na coleção users
        query = {'user_type': 'labelview_consultor'}
        
        # 🔧 Aplicar filtros opcionais (para Master)
        if unidade_id:
            query['unidade_id'] = unidade_id
            logger.info(f"🔍 Filtrando consultores por unidade: {unidade_id}")
        
        if regional_id:
            query['regional_id'] = regional_id
            logger.info(f"🔍 Filtrando consultores por regional: {regional_id}")
        
        # Se não for master, filtrar consultores da hierarquia
        if not current_user.get('is_labelview_master'):
            user_type = current_user.get('user_type')
            
            if user_type == 'labelview_unidade':
                # Unidade vê consultores vinculados a ela
                # Usando $or para pegar tanto por unidade_id quanto por referred_by (compatibilidade)
                query['$or'] = [
                    {'unidade_id': current_user['id']},
                    {'referred_by': current_user['id']}
                ]
            elif user_type == 'labelview_regional':
                # Regional vê consultores vinculados a ela
                query['$or'] = [
                    {'regional_id': current_user['id']},
                    {'referred_by': current_user['id']}
                ]
            else:
                # Para outros tipos, filtrar por referred_by (caso genérico)
                query['referred_by'] = current_user['id']
        
        logger.info(f"📋 Buscando consultores - Query: {query}")
        consultores = await db_instance.users.find(query).to_list(length=1000)
        logger.info(f"✅ Encontrados {len(consultores)} consultores")
        
        # Formatar resposta e enriquecer com dados de unidade e regional
        consultores_list = []
        for consultor in consultores:
            consultor.pop('_id', None)
            consultor.pop('password_hash', None)
            
            # Retornar temporary_password apenas se ainda não trocou
            if not consultor.get('must_change_password', False):
                consultor.pop('temporary_password', None)
            
            # Adicionar campo 'name' para o frontend (baseado no tipo)
            if consultor.get('natureza') == 'cpf':
                consultor['name'] = consultor.get('nome', consultor.get('full_name', '-'))
            else:
                consultor['name'] = consultor.get('nome_fantasia', consultor.get('razao_social', '-'))
            
            # Buscar nome da unidade
            if consultor.get('unidade_id'):
                unidade = await db_instance.users.find_one({'id': consultor['unidade_id']})
                consultor['unidade_nome'] = unidade.get('nome_fantasia') if unidade else '-'
            else:
                consultor['unidade_nome'] = '-'
            
            # Buscar nome da regional
            if consultor.get('regional_id'):
                regional = await db_instance.users.find_one({'id': consultor['regional_id']})
                consultor['regional_nome'] = regional.get('nome_fantasia') if regional else '-'
            else:
                consultor['regional_nome'] = '-'
            
            consultores_list.append(consultor)
        
        return {
            'success': True,
            'consultores': consultores_list,
            'total': len(consultores_list)
        }
    except Exception as e:
        logger.error(f"Error fetching consultores: {e}")
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.post("/consultores")
async def create_consultor(
    natureza: str = Form("cpf"),
    nome: Optional[str] = Form(None),
    nome_fantasia: Optional[str] = Form(None),
    razao_social: Optional[str] = Form(None),
    email_consultor: Optional[str] = Form(None),
    password_consultor: Optional[str] = Form(None),
    telefone: Optional[str] = Form(None),
    telefone_pf: Optional[str] = Form(None),
    cpf: Optional[str] = Form(None),
    rg: Optional[str] = Form(None),
    cnpj: Optional[str] = Form(None),
    cep: Optional[str] = Form(None),
    address: Optional[str] = Form(None),
    number: Optional[str] = Form(None),
    complement: Optional[str] = Form(None),
    neighborhood: Optional[str] = Form(None),
    city: Optional[str] = Form(None),
    state: Optional[str] = Form(None),
    pix_key: Optional[str] = Form(None),
    pix_key_type: Optional[str] = Form(None),
    unidade_id: Optional[str] = Form(None),
    regional_id: Optional[str] = Form(None),
    comissao_mensalidade_tipo: str = Form("percentual"),
    comissao_mensalidade_valor: float = Form(0.0),
    # 🔧 CORREÇÃO: Adicionados campos de upload de imagens RG
    rg_front: Optional[UploadFile] = File(None),
    rg_back: Optional[UploadFile] = File(None),
    current_user: dict = Depends(get_current_user_dependency)
):
    """Criar novo consultor"""
    from server import db as db_instance
    
    try:
        
        # Log dos dados recebidos
        logger.info(f"📥 Dados recebidos para criar consultor:")
        logger.info(f"  - natureza: {natureza}")
        logger.info(f"  - nome: {nome}")
        logger.info(f"  - cpf: {cpf}")
        logger.info(f"  - telefone_pf: {telefone_pf}")
        logger.info(f"  - email_consultor: {email_consultor}")
        logger.info(f"  - address: {address}")
        logger.info(f"  - city: {city}")
        logger.info(f"  - state: {state}")
        
        # Determinar nome e telefone final baseado na natureza
        if natureza == 'cpf':
            nome_final = nome
            telefone_final = telefone_pf
        else:  # cnpj
            nome_final = nome_fantasia or razao_social
            telefone_final = telefone
        
        logger.info(f"📋 Criando novo consultor ({natureza.upper()}): {nome_final}")
        
        # Validar hierarquia e determinar vínculos automaticamente
        user_type = current_user.get('user_type')
        
        if user_type == 'labelview_unidade':
            # Unidade criando Consultor
            # Usar unidade_id do Form se fornecido, senão usa o ID do current_user
            unidade_id_real = unidade_id if unidade_id else current_user.get('id')
            # regional_id vem do Form (opcional - Unidade pode escolher vincular a uma Regional)
            regional_id_real = regional_id  # Pode ser None
            logger.info(f"🏢 Unidade {unidade_id_real} criando Consultor (Regional: {regional_id_real or 'Nenhuma'})")
            
        elif user_type == 'labelview_regional':
            # Regional criando Consultor
            unidade_id_real = current_user.get('unidade_id')  # Unidade da Regional
            regional_id_real = current_user.get('id')  # Própria Regional
            logger.info(f"🏢 Regional {regional_id_real} criando Consultor para Unidade {unidade_id_real}")
            
        else:
            raise HTTPException(status_code=403, detail="Apenas Unidades e Regionais podem criar Consultores")
        
        # Validar campos obrigatórios
        if not nome_final:
            raise HTTPException(status_code=422, detail="Nome é obrigatório")
        if not telefone_final:
            raise HTTPException(status_code=422, detail="Telefone é obrigatório")
        
        # Gerar ID único
        consultor_id = str(uuid4())
        
        # Gerar credenciais se não fornecidas
        if not email_consultor:
            email_consultor = f"consultor.{consultor_id[:8]}@labelview.agitomil.com"
        
        temporary_password = password_consultor if password_consultor else "SenhaProvisoria2024!"
        password_hash = bcrypt.hash(temporary_password)
        
        logger.info(f"🔑 Credenciais geradas - Email: {email_consultor}")
        
        # 🔧 UPLOAD DE IMAGENS RG PARA CLOUDINARY
        rg_front_url = None
        rg_back_url = None
        
        if rg_front:
            try:
                logger.info(f"📸 Fazendo upload RG frente para Cloudinary...")
                rg_front_url = await upload_file_to_cloudinary(
                    rg_front,
                    folder=f"labelview/consultores/{consultor_id}",
                    filename=f"rg_front_{consultor_id}"
                )
                logger.info(f"✅ RG frente uploaded: {rg_front_url}")
            except Exception as e:
                logger.error(f"❌ Erro ao fazer upload RG frente: {e}")
        
        if rg_back:
            try:
                logger.info(f"📸 Fazendo upload RG verso para Cloudinary...")
                rg_back_url = await upload_file_to_cloudinary(
                    rg_back,
                    folder=f"labelview/consultores/{consultor_id}",
                    filename=f"rg_back_{consultor_id}"
                )
                logger.info(f"✅ RG verso uploaded: {rg_back_url}")
            except Exception as e:
                logger.error(f"❌ Erro ao fazer upload RG verso: {e}")
        
        # Log COMPLETO antes de salvar
        logger.info(f"=" * 80)
        logger.info(f"📝 CRIANDO CONSULTOR - DADOS COMPLETOS:")
        logger.info(f"   ID: {consultor_id}")
        logger.info(f"   Email: {email_consultor}")
        logger.info(f"   Natureza: {natureza}")
        logger.info(f"   Nome: {nome_final}")
        logger.info(f"   CPF: {cpf}")
        logger.info(f"   RG: {rg}")
        logger.info(f"   Telefone: {telefone_final}")
        logger.info(f"   CEP: {cep}")
        logger.info(f"   Address: {address}")
        logger.info(f"   Number: {number}")
        logger.info(f"   Complement: {complement}")
        logger.info(f"   Neighborhood: {neighborhood}")
        logger.info(f"   City: {city}")
        logger.info(f"   State: {state}")
        logger.info(f"   PIX Key: {pix_key}")
        logger.info(f"   PIX Type: {pix_key_type}")
        logger.info(f"   Unidade ID: {unidade_id_real}")
        logger.info(f"   Regional ID: {regional_id_real}")
        logger.info(f"=" * 80)
        
        # Criar usuário na coleção users
        user_data = {
            'id': consultor_id,
            'email': email_consultor,
            'password_hash': password_hash,
            'temporary_password': temporary_password,
            'full_name': nome_final,
            'phone': telefone_final or '',
            'user_type': 'labelview_consultor',
            'is_labelview_master': False,
            'is_active': True,
            'is_blocked': False,
            'must_change_password': True,
            'profile_complete': True,
            'balance': 0.0,
            'cashback_balance': 0.0,
            'created_at': datetime.utcnow().isoformat(),
            'updated_at': datetime.utcnow().isoformat(),
            
            # Dados específicos do Consultor
            'nome': nome_final,
            'telefone': telefone_final or '',
            'natureza': natureza,
            
            # Dados PF
            'cpf': cpf or '',
            'rg': rg or '',
            'rg_front_url': rg_front_url or '',
            'rg_back_url': rg_back_url or '',
            
            # Dados PJ
            'nome_fantasia': nome_fantasia or '',
            'razao_social': razao_social or '',
            'cnpj': cnpj or '',
            
            # Endereço
            'cep': cep or '',
            'address': address or '',
            'street': address or '',  # Alias
            'number': number or '',
            'complement': complement or '',
            'neighborhood': neighborhood or '',
            'city': city or '',
            'state': state or '',
            
            # PIX
            'pix_key': pix_key or '',
            'pix_key_type': pix_key_type or '',
            
            # Hierarquia Labelview
            'unidade_id': unidade_id_real,  # Unidade a qual pertence
            'regional_id': regional_id_real,  # Regional (se houver)
            
            # Comissão
            'comissao_mensalidade_tipo': comissao_mensalidade_tipo,
            'comissao_mensalidade_valor': comissao_mensalidade_valor,
            
            # Referral Transmill - Consultor criado pela Regional ou Unidade
            'referred_by': current_user['id'],  # Quem criou (Regional ou Unidade)
            'referral_code': f"CONS_{consultor_id[:8].upper()}",  # Código próprio do consultor
            'referral_code_used': current_user.get('referral_code', ''),  # Código de quem indicou
        }
        
        # Inserir no banco de dados com tratamento robusto
        try:
            insert_result = await db_instance.users.insert_one(user_data)
            logger.info(f"✅ INSERT executado - ID MongoDB: {insert_result.inserted_id}")
            logger.info(f"✅ Acknowledged: {insert_result.acknowledged}")
        except Exception as insert_error:
            logger.error(f"❌ ERRO CRÍTICO NO INSERT: {str(insert_error)}")
            logger.error(f"❌ Tipo do erro: {type(insert_error)}")
            raise HTTPException(status_code=500, detail=f"Erro ao salvar no banco: {str(insert_error)}")
        
        # VERIFICAÇÃO CRÍTICA: Buscar de volta do banco
        consultor_salvo = await db_instance.users.find_one({'id': consultor_id})
        if consultor_salvo:
            logger.info(f"✅ VERIFICAÇÃO: Consultor encontrado no banco")
            logger.info(f"   - Nome: {consultor_salvo.get('nome')}")
            logger.info(f"   - CPF: {consultor_salvo.get('cpf')}")
            logger.info(f"   - Telefone: {consultor_salvo.get('telefone')}")
            logger.info(f"   - City: {consultor_salvo.get('city')}")
            logger.info(f"   - State: {consultor_salvo.get('state')}")
            logger.info(f"   - Email: {consultor_salvo.get('email')}")
        else:
            logger.error(f"❌❌❌ ERRO CRÍTICO: Consultor NÃO encontrado no banco após insert!")
            logger.error(f"❌ INSERT disse sucesso mas consultor não está no banco!")
            raise HTTPException(status_code=500, detail="Consultor não foi salvo no banco de dados")
        
        logger.info(f"✅ Consultor {consultor_id} criado com sucesso")
        
        return {
            'success': True,
            'message': 'Consultor criado com sucesso',
            'consultor_id': consultor_id,
            'credentials': {
                'email': email_consultor,
                'password': temporary_password
            }
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erro ao criar consultor: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"Erro ao criar consultor: {str(e)}")


@labelview_router.patch("/consultores/{consultor_id}/block")
async def toggle_block_consultor(
    consultor_id: str,
    current_user: dict = Depends(get_current_user_dependency)
):
    """Bloquear/Desbloquear consultor"""
    from server import db as db_instance
    
    try:
        # Buscar consultor
        consultor = await db_instance.users.find_one({'id': consultor_id, 'user_type': 'labelview_consultor'})
        if not consultor:
            raise HTTPException(status_code=404, detail="Consultor não encontrado")
        
        # Alternar status de bloqueio
        new_status = not consultor.get('is_blocked', False)
        
        await db_instance.users.update_one(
            {'id': consultor_id},
            {'$set': {'is_blocked': new_status, 'updated_at': datetime.utcnow().isoformat()}}
        )
        
        logger.info(f"✅ Consultor {consultor_id} {'bloqueado' if new_status else 'desbloqueado'}")
        
        return {
            'success': True,
            'message': f"Consultor {'bloqueado' if new_status else 'desbloqueado'} com sucesso",
            'is_blocked': new_status
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erro ao alterar status do consultor: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"Erro ao alterar status: {str(e)}")


@labelview_router.delete("/consultores/{consultor_id}")
async def delete_consultor(
    consultor_id: str,
    current_user: dict = Depends(get_current_user_dependency)
):
    """Deletar consultor"""
    from server import db as db_instance
    
    try:
        # Buscar consultor
        consultor = await db_instance.users.find_one({'id': consultor_id, 'user_type': 'labelview_consultor'})
        if not consultor:
            raise HTTPException(status_code=404, detail="Consultor não encontrado")
        
        # Deletar consultor
        await db_instance.users.delete_one({'id': consultor_id})
        
        logger.info(f"✅ Consultor {consultor_id} deletado com sucesso")
        
        return {
            'success': True,
            'message': 'Consultor deletado com sucesso'
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erro ao deletar consultor: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"Erro ao deletar consultor: {str(e)}")


# ============================================
# CLIENTES LABELVIEW
# ============================================

@labelview_router.get("/clients-detailed")
async def get_clients_detailed(
    referred_by: Optional[str] = Query(None),
    unidade_id: Optional[str] = Query(None),
    regional_id: Optional[str] = Query(None),
    consultor_id: Optional[str] = Query(None),
    current_user: dict = Depends(get_current_user_dependency)
):
    """Listar clientes com filtros hierárquicos"""
    try:
        logger.info(f"📋 Buscando clientes - user: {current_user.get('user_type')}, filtros: referred_by={referred_by}, unidade_id={unidade_id}, regional_id={regional_id}, consultor_id={consultor_id}")
        
        # Construir query baseado no tipo de usuário e filtros
        query = {'user_type': 'cliente'}
        
        # Consultor: só vê clientes próprios
        if current_user.get('user_type') == 'labelview_consultor':
            query['referred_by'] = current_user['id']
        
        # Regional: vê próprios ou filtra por consultor
        elif current_user.get('user_type') == 'labelview_regional':
            if referred_by:
                query['referred_by'] = referred_by
            elif consultor_id:
                # Buscar clientes do consultor
                query['referred_by'] = consultor_id
            else:
                # Clientes próprios do regional
                query['referred_by'] = current_user['id']
        
        # Unidade: vê próprios, por regional ou por consultor
        elif current_user.get('user_type') == 'labelview_unidade':
            if referred_by:
                query['referred_by'] = referred_by
            elif regional_id:
                # Buscar clientes criados por este regional
                query['referred_by'] = regional_id
            elif consultor_id:
                # Buscar clientes criados por este consultor
                query['referred_by'] = consultor_id
            else:
                # Clientes próprios da unidade
                query['referred_by'] = current_user['id']
        
        # Master: filtra por unidade ou vê todos
        elif current_user.get('is_labelview_master'):
            if unidade_id:
                # Buscar clientes da hierarquia desta unidade
                # Isso inclui clientes criados pela unidade, regionais e consultores
                unidade_users = await db_instance.users.find({
                    '$or': [
                        {'id': unidade_id},
                        {'unidade_id': unidade_id}
                    ]
                }).to_list(length=10000)
                
                user_ids = [u['id'] for u in unidade_users]
                query['referred_by'] = {'$in': user_ids}
            # Se não especificar unidade, retorna todos os clientes
        
        # Buscar clientes
        clientes = await db_instance.users.find(query).to_list(length=10000)
        
        # Enriquecer dados dos clientes
        clientes_detalhados = []
        for cliente in clientes:
            cliente.pop('_id', None)
            cliente.pop('password_hash', None)
            
            # Buscar quem indicou
            if cliente.get('referred_by'):
                referrer = await db_instance.users.find_one({'id': cliente['referred_by']})
                if referrer:
                    cliente['indicado_por'] = {
                        'id': referrer.get('id'),
                        'nome': referrer.get('full_name') or referrer.get('nome') or referrer.get('nome_fantasia'),
                        'tipo': referrer.get('user_type')
                    }
            
            clientes_detalhados.append(cliente)
        
        logger.info(f"✅ Encontrados {len(clientes_detalhados)} clientes")
        
        return {
            'success': True,
            'clients': clientes_detalhados,
            'total': len(clientes_detalhados)
        }
        
    except Exception as e:
        logger.error(f"❌ Erro ao buscar clientes: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=str(e))


# ============================================
# TIPOS DE VEÍCULO
# ============================================

@labelview_router.get("/tipos-veiculo")
async def get_tipos_veiculo(
    current_user: dict = Depends(get_current_user_dependency)
):
    """Listar tipos de veículo disponíveis"""
    from server import db as db_instance
    try:
        logger.info("📋 GET /tipos-veiculo iniciado")
        
        # Buscar tipos de veículo da coleção
        tipos = await db_instance.labelview_tipos_veiculo.find({}).to_list(length=1000)
        
        logger.info(f"📦 {len(tipos)} tipos encontrados no banco de dados")
        
        # Se não houver tipos cadastrados, retornar tipos padrão
        if not tipos:
            tipos_padrao = [
                {
                    'id': 'carro',
                    'nome': 'Carro',
                    'tipo_fipe': 'carros',
                    'icone': '🚗',
                    'ativo': True
                },
                {
                    'id': 'moto',
                    'nome': 'Moto',
                    'tipo_fipe': 'motos',
                    'icone': '🏍️',
                    'ativo': True
                },
                {
                    'id': 'caminhao',
                    'nome': 'Caminhão',
                    'tipo_fipe': 'caminhoes',
                    'icone': '🚚',
                    'ativo': True
                }
            ]
            tipos = tipos_padrao
        
        # Remover _id do MongoDB e mapear campos para o frontend
        for tipo in tipos:
            if '_id' in tipo:
                tipo.pop('_id')
            # Garantir compatibilidade: mapear 'ativo' para 'is_active' também
            if 'ativo' in tipo and 'is_active' not in tipo:
                tipo['is_active'] = tipo['ativo']
            
            # Log das imagens para cada tipo
            imagens = tipo.get('imagens_vistoria', [])
            logger.info(f"📸 Tipo '{tipo.get('nome')}' tem {len(imagens)} imagens no banco")
        
        return {
            'success': True,
            'tipos': tipos,
            'total': len(tipos)
        }
    except Exception as e:
        logger.error(f"❌ Error fetching tipos veiculo: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail=str(e))



@labelview_router.post("/tipos-veiculo")
async def create_tipo_veiculo(
    dados: dict,
    current_user: dict = Depends(get_current_user_dependency)
):
    """Criar novo tipo de veículo (apenas Master)"""
    from server import db as db_instance
    
    # Verificar se é Master
    if not current_user.get('is_labelview_master') and current_user.get('user_type') != 'labelview_master':
        raise HTTPException(status_code=403, detail="Apenas Master pode criar tipos de veículo")
    
    try:
        # ✅ IMPORTANTE: Adicionar campo tipo_fipe para busca FIPE
        # Mapear categoria para tipo_fipe
        categoria = dados.get('categoria', '').lower()
        tipo_fipe = 'carros'  # Padrão
        
        if 'moto' in categoria or 'motocicleta' in categoria:
            tipo_fipe = 'motos'
        elif 'caminhão' in categoria or 'caminhao' in categoria or 'caminhonete' in categoria:
            tipo_fipe = 'caminhoes'
        
        novo_tipo = {
            'id': str(uuid4()),
            'nome': dados.get('nome'),
            'categoria': dados.get('categoria'),
            'tipo_fipe': tipo_fipe,  # Para busca na tabela FIPE
            'ativo': dados.get('ativo', True),
            'valor_fipe_maximo': dados.get('valor_fipe_maximo', 120000),
            'imagens_vistoria': dados.get('imagens_vistoria', []),
            'created_at': datetime.utcnow(),
            'created_by': current_user['id']
        }
        
        await db_instance.labelview_tipos_veiculo.insert_one(novo_tipo)
        novo_tipo.pop('_id', None)
        
        logger.info(f"✅ Tipo de veículo criado: {novo_tipo['nome']} (tipo_fipe: {tipo_fipe})")
        
        return {
            'success': True,
            'message': 'Tipo de veículo criado',
            'tipo': novo_tipo
        }
    except Exception as e:
        logger.error(f"Erro ao criar tipo de veículo: {e}")
        raise HTTPException(status_code=500, detail=str(e))



# =====================================================
# UPLOAD DE IMAGEM PARA TIPO DE VEÍCULO
# =====================================================
@labelview_router.post("/upload-imagem-tipo-veiculo")
async def upload_imagem_tipo_veiculo(
    imagem_base64: str = Form(...),
    nome_campo: str = Form(...),
    tipo_veiculo_id: str = Form(...),
    current_user: dict = Depends(get_current_user_dependency)
):
    """
    Endpoint para fazer upload de imagem para tipo de veículo
    Recebe imagem em base64 e faz upload para Cloudinary
    """
    # Verificar se é Master
    if not current_user.get('is_labelview_master') and current_user.get('user_type') != 'labelview_master':
        raise HTTPException(status_code=403, detail="Apenas Master pode fazer upload de imagens")
    
    try:
        import base64
        import io
        
        # Extrair dados base64 (remover prefixo data:image/...;base64,)
        if ',' in imagem_base64:
            imagem_base64 = imagem_base64.split(',')[1]
        
        # Decodificar base64
        try:
            image_bytes = base64.b64decode(imagem_base64)
        except Exception as e:
            raise HTTPException(status_code=400, detail="Imagem base64 inválida")
        
        # Validar tamanho (máx 5MB)
        file_size = len(image_bytes)
        if file_size > 5 * 1024 * 1024:  # 5MB
            raise HTTPException(status_code=400, detail="Imagem muito grande. Máximo: 5MB")
        
        # Gerar nome de arquivo
        import uuid
        filename = f"{tipo_veiculo_id}_{nome_campo}_{uuid.uuid4().hex[:8]}.jpg"
        
        logger.info(f"📤 Fazendo upload de imagem tipo veículo: {nome_campo} ({file_size} bytes)")
        
        # Fazer upload para Cloudinary
        image_url = await upload_file_to_cloudinary(
            file_content=image_bytes,
            filename=filename,
            folder='tipos_veiculo'
        )
        
        if not image_url:
            raise HTTPException(status_code=500, detail="Erro ao fazer upload da imagem para Cloudinary")
        
        logger.info(f"✅ Upload concluído: {image_url}")
        
        return {
            'success': True,
            'url': image_url,
            'filename': filename,
            'size': file_size
        }
        
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erro no upload de imagem tipo veículo: {e}")
        raise HTTPException(status_code=500, detail=f"Erro ao fazer upload: {str(e)}")


@labelview_router.patch("/tipos-veiculo/{tipo_id}")
async def update_tipo_veiculo(
    tipo_id: str,
    dados: dict,
    current_user: dict = Depends(get_current_user_dependency)
):
    """Atualizar tipo de veículo (apenas Master)"""
    from server import db as db_instance
    
    # Verificar se é Master
    if not current_user.get('is_labelview_master') and current_user.get('user_type') != 'labelview_master':
        raise HTTPException(status_code=403, detail="Apenas Master pode editar tipos de veículo")
    
    try:
        # Log detalhado dos dados recebidos
        logger.info(f"🔄 PATCH /tipos-veiculo/{tipo_id} iniciado")
        logger.info(f"📦 Dados recebidos: {list(dados.keys())}")
        
        # ✅ Atualizar tipo_fipe baseado na categoria
        categoria = dados.get('categoria', '').lower()
        tipo_fipe = 'carros'  # Padrão
        
        if 'moto' in categoria or 'motocicleta' in categoria:
            tipo_fipe = 'motos'
        elif 'caminhão' in categoria or 'caminhao' in categoria or 'caminhonete' in categoria:
            tipo_fipe = 'caminhoes'
        
        # Log detalhado das imagens
        imagens_recebidas = dados.get('imagens_vistoria', [])
        logger.info(f"📸 RECEBENDO {len(imagens_recebidas)} imagens para salvar no tipo {tipo_id}")
        
        if imagens_recebidas:
            logger.info(f"📋 Primeiras imagens recebidas: {imagens_recebidas[:2] if len(imagens_recebidas) >= 2 else imagens_recebidas}")
        else:
            logger.warning(f"⚠️ NENHUMA IMAGEM RECEBIDA para o tipo {tipo_id}!")
        
        update_data = {
            'nome': dados.get('nome'),
            'categoria': dados.get('categoria'),
            'tipo_fipe': tipo_fipe,
            'ativo': dados.get('ativo'),
            'valor_fipe_maximo': dados.get('valor_fipe_maximo', 120000),
            'imagens_vistoria': imagens_recebidas,
            'updated_at': datetime.utcnow()
        }
        
        # Log antes do update
        logger.info(f"💾 Salvando no MongoDB - total de imagens: {len(update_data['imagens_vistoria'])}")
        
        resultado = await db_instance.labelview_tipos_veiculo.update_one(
            {'id': tipo_id},
            {'$set': update_data}
        )
        
        logger.info(f"📊 MongoDB resultado - matched: {resultado.matched_count}, modified: {resultado.modified_count}")
        
        if resultado.matched_count == 0:
            raise HTTPException(status_code=404, detail="Tipo de veículo não encontrado")
        
        # Verificar o que foi salvo
        tipo_salvo = await db_instance.labelview_tipos_veiculo.find_one({'id': tipo_id})
        if tipo_salvo:
            imagens_salvas = tipo_salvo.get('imagens_vistoria', [])
            logger.info(f"✅ Verificação: {len(imagens_salvas)} imagens CONFIRMADAS no banco de dados")
        
        logger.info(f"✅ Tipo de veículo atualizado com sucesso: {tipo_id}")
        
        return {
            'success': True,
            'message': 'Tipo de veículo atualizado',
            'imagens_salvas': len(imagens_recebidas)
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erro ao atualizar tipo de veículo: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.delete("/tipos-veiculo/{tipo_id}")
async def delete_tipo_veiculo(
    tipo_id: str,
    current_user: dict = Depends(get_current_user_dependency)
):
    """Deletar tipo de veículo (apenas Master)"""
    from server import db as db_instance
    
    # Verificar se é Master
    if not current_user.get('is_labelview_master') and current_user.get('user_type') != 'labelview_master':
        raise HTTPException(status_code=403, detail="Apenas Master pode deletar tipos de veículo")
    
    try:
        logger.info(f"🗑️ DELETE /tipos-veiculo/{tipo_id} iniciado")
        
        # Verificar se o tipo existe
        tipo = await db_instance.labelview_tipos_veiculo.find_one({'id': tipo_id})
        if not tipo:
            raise HTTPException(status_code=404, detail="Tipo de veículo não encontrado")
        
        # Deletar o tipo
        resultado = await db_instance.labelview_tipos_veiculo.delete_one({'id': tipo_id})
        
        if resultado.deleted_count == 0:
            raise HTTPException(status_code=500, detail="Erro ao deletar tipo de veículo")
        
        logger.info(f"✅ Tipo de veículo deletado com sucesso: {tipo_id}")
        
        return {
            'success': True,
            'message': 'Tipo de veículo deletado com sucesso'
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"❌ Erro ao deletar tipo de veículo: {e}", exc_info=True)
        raise HTTPException(status_code=500, detail=str(e))


@labelview_router.post("/upload-foto-vistoria")
async def upload_foto_vistoria(
    imagem_base64: str = Form(...),
    nome_campo: str = Form(...),
    cotacao_temp_id: str = Form(...),
    current_user: dict = Depends(get_current_user_dependency)
):
    """Upload de foto de vistoria para Cloudinary"""
    from server import db as db_instance
    try:
        logger.info(f"📸 Upload de foto de vistoria - campo: {nome_campo}")
        
        # Decodificar base64 e fazer upload para Cloudinary
        import base64
        import re
        
        # Remover prefixo data:image/...;base64,
        base64_data = re.sub('^data:image/.+;base64,', '', imagem_base64)
        image_bytes = base64.b64decode(base64_data)
        
        # Upload para Cloudinary
        filename = f"vistoria_{nome_campo}_{cotacao_temp_id}"
        cloudinary_url = await upload_file_to_cloudinary(
            file_content=image_bytes,
            filename=filename,
            folder="labelview/vistorias",
            resource_type="image"
        )
        
        if not cloudinary_url:
            raise HTTPException(status_code=500, detail="Erro ao fazer upload para Cloudinary")
        
        logger.info(f"✅ Foto de vistoria enviada: {cloudinary_url}")
        
        return {
            'success': True,
            'url': cloudinary_url,
            'campo': nome_campo
        }
        
    except Exception as e:
        logger.error(f"❌ Erro ao fazer upload de foto de vistoria: {str(e)}", exc_info=True)
        raise HTTPException(status_code=500, detail=f"Erro ao fazer upload: {str(e)}")


