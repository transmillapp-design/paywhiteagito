@labelview_router.get("/commission-rules")
async def get_commission_rules(
    current_user = Depends(get_current_user_dependency)
):
    """Buscar regras de comissão"""
    from server import db as db_instance
    await verify_labelview_master(current_user["id"])
    
    try:
        rules = await db_instance.labelview_commission_rules.find_one({})
        
        if not rules:
            # Criar regras padrão
            rules = {
                'id': str(uuid4()),
                'labelview_percentage': 50.0,
                'agitoauto_percentage': 20.0,
                'mini_agency_percentage': 10.0,
                'consultant_percentage': 10.0,
                'cashback_percentage': 10.0,
                'updated_at': datetime.utcnow()
            }
            await db_instance.labelview_commission_rules.insert_one(rules)
        
        return {
            'success': True,
            'rules': rules
        }
    except Exception as e:
        logger.error(f"Error fetching commission rules: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@labelview_router.post("/commission-rules")
async def update_commission_rules(
    rules_data: dict,
    current_user = Depends(get_current_user_dependency)
):
    """Atualizar regras de comissão"""
    from server import db as db_instance
    await verify_labelview_master(current_user["id"])
    
    try:
        # Validar que soma das porcentagens = 100%
        total = (
            rules_data.get('labelview_percentage', 0) +
            rules_data.get('agitoauto_percentage', 0) +
            rules_data.get('mini_agency_percentage', 0) +
            rules_data.get('consultant_percentage', 0) +
            rules_data.get('cashback_percentage', 0)
        )
        
        if abs(total - 100.0) > 0.01:
            raise HTTPException(
                status_code=400, 
                detail=f"Soma das porcentagens deve ser 100%. Atual: {total}%"
            )
        
        rules_data['updated_at'] = datetime.utcnow()
        rules_data['updated_by'] = current_user["id"]
        
        existing = await db_instance.labelview_commission_rules.find_one({})
        
        if existing:
            await db_instance.labelview_commission_rules.update_one(
                {'id': existing['id']},
                {'$set': rules_data}
            )
        else:
            rules_data['id'] = str(uuid4())
            await db_instance.labelview_commission_rules.insert_one(rules_data)
        
        return {
            'success': True,
            'message': 'Regras de comissão atualizadas com sucesso',
            'rules': rules_data
        }
    except HTTPException:
        raise
    except Exception as e:
        logger.error(f"Error updating commission rules: {e}")
        raise HTTPException(status_code=500, detail=str(e))

