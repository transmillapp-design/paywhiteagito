@labelview_router.get("/employees")
async def get_employees(
    current_user = Depends(get_current_user_dependency)
):
    """Listar colaboradores"""
    from server import db as db_instance
    await verify_labelview_master(current_user["id"])
    
    try:
        employees = await db_instance.labelview_employees.find({}).to_list(length=1000)
        
        # Remove MongoDB _id field to avoid serialization issues
        for employee in employees:
            if '_id' in employee:
                employee.pop('_id')
        
        return {
            'success': True,
            'employees': employees,
            'total': len(employees)
        }
    except Exception as e:
        logger.error(f"Error fetching employees: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@labelview_router.post("/employees")
async def create_employee(
    employee_data: dict,
    current_user = Depends(get_current_user_dependency)
):
    """Criar novo colaborador"""
    from server import db as db_instance
    await verify_labelview_master(current_user["id"])
    
    try:
        employee = {
            'id': str(uuid4()),
            'full_name': employee_data.get('full_name'),
            'cpf': employee_data.get('cpf'),
            'email': employee_data.get('email'),
            'phone': employee_data.get('phone'),
            'role': employee_data.get('role'),
            'regional': employee_data.get('regional'),
            'commission_percentage': employee_data.get('commission_percentage', 0.0),
            'is_active': True,
            'created_at': datetime.utcnow()
        }
        
        # Validate required fields
        required_fields = ['full_name', 'email', 'role']
        missing_fields = [field for field in required_fields if not employee_data.get(field)]
        if missing_fields:
            raise HTTPException(status_code=400, detail=f"Missing required fields: {', '.join(missing_fields)}")
        
        await db_instance.labelview_employees.insert_one(employee)
        
        # Remove _id from response to avoid serialization issues
        employee_response = employee.copy()
        employee_response.pop('_id', None)
        
        return {
            'success': True,
            'message': 'Colaborador criado com sucesso',
            'employee': employee_response
        }
    except Exception as e:
        logger.error(f"Error creating employee: {e}")
        raise HTTPException(status_code=500, detail=str(e))

@labelview_router.put("/employees/{employee_id}")
async def update_employee(
    employee_id: str,
    employee_data: dict,
    current_user = Depends(get_current_user_dependency)
):
    """Atualizar colaborador"""
    await verify_labelview_master(current_user["id"])
    
    try:
        employee_data['updated_at'] = datetime.utcnow()
        
        result = await db_instance.labelview_employees.update_one(
            {'id': employee_id},
            {'$set': employee_data}
        )
        
        if result.modified_count == 0:
            raise HTTPException(status_code=404, detail="Colaborador não encontrado")
        
        return {
            'success': True,
            'message': 'Colaborador atualizado com sucesso'
        }
    except Exception as e:
        logger.error(f"Error updating employee: {e}")
        raise HTTPException(status_code=500, detail=str(e))

