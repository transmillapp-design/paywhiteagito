@labelview_router.get("/debug/last-unidades")
async def debug_last_unidades():
    """Debug: Verificar últimas unidades criadas"""
    from server import db as db_instance
    
    try:
        # Buscar últimas 3 unidades
        unidades = await db_instance.users.find(
            {'user_type': 'labelview_unidade'}
        ).sort('created_at', -1).limit(3).to_list(length=3)
        
        # Formatar resposta
        result = []
        for u in unidades:
            result.append({
                'id': u.get('id'),
                'nome_fantasia': u.get('nome_fantasia'),
                'email': u.get('email'),
                'logo_url': u.get('logo_url'),
                'contrato_social_url': u.get('contrato_social_url'),
                'doc_cnpj_url': u.get('doc_cnpj_url'),
                'created_at': u.get('created_at'),
                'has_logo': bool(u.get('logo_url')),
                'has_docs': bool(u.get('contrato_social_url') or u.get('doc_cnpj_url'))
            })
        
        return {
            'success': True,
            'total': len(result),
            'unidades': result
        }
    except Exception as e:
        return {
            'success': False,
            'error': str(e)
        }

